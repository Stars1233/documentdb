{
  "NodeHostName": "localhost",
  "BlockedRolePrefixes": [
    "documentdb",
    "citus",
    "pg",
    "internal_role"
  ],
  "PostgresPort": 9712,
  "GatewayListenPort": 10260,
  "HostConfigurationWatchIntervalMs": 1000,
  "CertificateOptions": {
    "CertType": "PemAutoGenerated"
  },
  "UseLocalHost": false,
  "_comment_TelemetryOptions": "Telemetry is opt-in. Enable Metrics and/or Tracing below, then point OtlpEndpoint at your collector. Env vars OTEL_EXPORTER_OTLP_ENDPOINT, OTEL_TRACES_SAMPLER_ARG, etc. provide further overrides per the OpenTelemetry spec.",
  "TelemetryOptions": {
    "ServiceName": "documentdb_gateway",
    "Metrics": {
      "Enabled": false,
      "OtlpEndpoint": "http://localhost:4317",
      "ExportIntervalMs": 15000
    },
    "Tracing": {
      "Enabled": false,
      "OtlpEndpoint": "http://localhost:4317",
      "SamplerRatio": 1.0,
      "ExportTimeoutMs": 10000
    }
  }
}