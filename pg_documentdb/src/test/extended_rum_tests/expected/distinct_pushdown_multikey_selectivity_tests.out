SET search_path TO documentdb_api,documentdb_core,documentdb_api_catalog,documentdb_api_internal,public;
-- ============================================================
-- Distinct pushdown row-estimate correctness on a SPARSE, multikey
-- leading index column.
--
-- Index { a: 1, b: 1 } where "a" is:
--   * multikey  (array values), and
--   * sparse    (only ~20% of documents contain the path "a").
-- distinct key = "a"  (leading column 0), query filter = range on "b".
--
-- For a multikey distinct the order-by cannot be pushed down, so an
-- implicit "a >= MinKey" ($exists:true) boundary is injected onto the
-- index path. Historically that boundary was attached to the index
-- clauses only, so it never fed back into the index path's row
-- estimate: the implicit-distinct index path reported the same rows as
-- the plain "b" range (the whole b-filtered set), which is as large as
-- the sequential scan estimate. As a result the planner treated the
-- index scan and the sequential scan as interchangeable and could fall
-- back to the sequential scan.
--
-- The fix records the injected boundary and multiplies the index path
-- row estimate by its (sparse) selectivity, so the implicit-distinct
-- index path now estimates the same, lower row count that an explicit
-- { a: { $exists: true } } filter produces.
--
-- The explicit { a: { $exists: true } } case must NOT be reduced twice:
-- when the caller already constrains "a" (either through a query clause
-- or through the index's partial filter expression), the injected
-- boundary is redundant and is skipped, so the row estimate is reduced
-- exactly once.
--
-- These tests assert the *behavior* (comparisons of parsed index-path row
-- estimates against each other) rather than printing absolute cost/row
-- numbers, so they are deterministic across environments and PostgreSQL
-- versions. The estimates are only ever compared against other index-path
-- estimates that share the same selectivity estimator; the sequential
-- scan estimate is intentionally not compared, because the plain scan and
-- the pushed-down index scan derive their base row counts from different
-- selectivity estimators whose values are planner-version dependent.
-- ============================================================
SET documentdb.defaultUseCompositeOpClass TO on;
-- Ensure database 'db' exists so the system.dbSentinel collection does
-- not consume a test collection ID when running in standalone mode.
SELECT documentdb_api.insert_one('db', 'mk_sel_sentinel', '{ "_id": 0 }');
NOTICE:  creating collection
                              insert_one                              
----------------------------------------------------------------------
 { "n" : { "$numberInt" : "1" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

SELECT documentdb_api.drop_collection('db', 'mk_sel_sentinel');
 drop_collection 
-----------------
 t
(1 row)

-- Set the collection/index id base once for the whole test (must be a
-- multiple of 100). The two collections created below (dpk, dpkpfe) take
-- sequential ids from this base.
SET documentdb.next_collection_id TO 23500;
SET documentdb.next_collection_index_id TO 23500;
-- Compound index on { a: 1, b: 1 }.
SELECT documentdb_api_internal.create_indexes_non_concurrently('db', '{ "createIndexes": "dpk", "indexes": [ { "key": { "a": 1, "b": 1 }, "name": "idx_a_b" } ] }', true);
NOTICE:  creating collection
                                                                                                   create_indexes_non_concurrently                                                                                                   
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 { "raw" : { "defaultShard" : { "numIndexesBefore" : { "$numberInt" : "1" }, "numIndexesAfter" : { "$numberInt" : "2" }, "createdCollectionAutomatically" : true, "ok" : { "$numberInt" : "1" } } }, "ok" : { "$numberInt" : "1" } }
(1 row)

-- 80% of docs: only "b" (no "a" path at all -> "a" is SPARSE).
SELECT COUNT(documentdb_api.insert_one('db', 'dpk',
    format('{ "_id": %s, "b": %s }', i, i)::documentdb_core.bson))
FROM generate_series(1, 8000) AS i;
 count 
-------
  8000
(1 row)

-- 20% of docs: "a" present as an ARRAY (multikey) plus "b".
SELECT COUNT(documentdb_api.insert_one('db', 'dpk',
    format('{ "_id": %s, "a": [%s, %s], "b": %s }',
           i, i % 10, (i + 1) % 10, i)::documentdb_core.bson))
FROM generate_series(8001, 10000) AS i;
 count 
-------
  2000
(1 row)

-- Full ANALYZE (the whole table is well under the sample size) so the
-- planner statistics are exact and the estimates are deterministic.
ANALYZE;
-- Planner statistics + composite planner + btree-stats selectivity.
SET documentdb.enable_index_correlation_from_statistics TO on;
SET documentdb.enablePerCollectionPlannerStatistics TO on;
SET documentdb.enablePlannerStatisticsNewCollections TO on;
SET documentdb.enableCompositeIndexPlanner TO on;
SET documentdb_core.enableBsonSelectivityFromBtreeStats TO on;
SET documentdb.enableExtendedExplainPlans TO on;
-- Helper: run a distinct query with the pushed-down index scan forced and
-- return the estimated row count of the underlying index scan node parsed
-- out of the JSON explain output. The scan-enable GUCs are set on every
-- call so repeated invocations within a single statement do not leak
-- settings into one another.
CREATE OR REPLACE FUNCTION pg_temp.distinct_index_rows(spec text)
RETURNS numeric
LANGUAGE plpgsql
AS $fn$
DECLARE
    explainJson jsonb;
    scanRows numeric;
BEGIN
    PERFORM set_config('documentdb.enableDistinctIndexPushdown', 'on', true);
    PERFORM set_config('enable_seqscan', 'off', true);
    PERFORM set_config('enable_indexscan', 'on', true);
    PERFORM set_config('enable_indexonlyscan', 'on', true);
    PERFORM set_config('enable_bitmapscan', 'off', true);

    EXECUTE format(
        'EXPLAIN (COSTS ON, FORMAT JSON) SELECT document FROM documentdb_api_catalog.bson_aggregation_distinct(%L, %L::documentdb_core.bson)',
        'db', spec) INTO explainJson;

    SELECT (planNode->>'Plan Rows')::numeric
    INTO scanRows
    FROM jsonb_path_query(explainJson, 'strict $.**') AS planNode
    WHERE planNode->>'Node Type' IN ('Index Scan', 'Index Only Scan', 'Bitmap Heap Scan')
    ORDER BY (planNode->>'Plan Rows')::numeric
    LIMIT 1;

    RETURN scanRows;
END
$fn$;
-- ------------------------------------------------------------
-- Assertion 1: the implicit-distinct index path row estimate matches the
-- explicit { a: { $exists: true } } index path row estimate on the same
-- collection and index.
--
-- The explicit form places { a: { $exists: true } } in the base
-- restriction, so its index path is reduced by the sparse exists
-- selectivity exactly once. The implicit form has no "a" clause and relies
-- on the injected boundary being folded into the estimate.
--
-- Without the fix the implicit path is NOT reduced by the sparse exists
-- selectivity, so it estimates the full b-filtered set -- many more rows
-- than the explicit path -> FALSE. With the fix both estimate the same
-- reduced count -> TRUE.
--
-- This single equality also guards against a double reduction of the
-- explicit path: if the redundant boundary were injected on top of the
-- explicit base restriction, the explicit estimate would drop below the
-- implicit estimate and the equality would fail.
-- ------------------------------------------------------------
SELECT pg_temp.distinct_index_rows('{ "distinct": "dpk", "key": "a", "query": { "b": { "$gte": 1 } } }')
     = pg_temp.distinct_index_rows('{ "distinct": "dpk", "key": "a", "query": { "b": { "$gte": 1 }, "a": { "$exists": true } } }')
  AS implicit_index_matches_explicit_exists;
 implicit_index_matches_explicit_exists 
----------------------------------------
 t
(1 row)

-- ============================================================
-- Partial index variant: the leading distinct column "a" is constrained
-- by the index's partial filter expression rather than by a query clause.
--
-- Index { a: 1, b: 1 } WHERE { a: { $exists: true } }. A query that
-- carries { a: { $exists: true } } (to match the partial filter) has that
-- predicate stripped when matched against the index predicate, so the
-- order-by traversal sees only the "b" range plus fullscan(a) and would
-- otherwise treat "a" as unconstrained and inject a redundant
-- "a >= MinKey" boundary. Because the partial filter already constrains
-- "a", that injected boundary is redundant and must be skipped -- the
-- partial-filter walk records that column 0 is specified, which blocks the
-- injection. Without that, the index path row estimate is reduced a second
-- time by the sparse exists selectivity.
-- ============================================================
-- Partial compound index on { a: 1, b: 1 } WHERE a exists.
SELECT documentdb_api_internal.create_indexes_non_concurrently('db', '{ "createIndexes": "dpkpfe", "indexes": [ { "key": { "a": 1, "b": 1 }, "name": "idx_a_b_pfe", "partialFilterExpression": { "a": { "$exists": true } } } ] }', true);
NOTICE:  creating collection
                                                                                                   create_indexes_non_concurrently                                                                                                   
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 { "raw" : { "defaultShard" : { "numIndexesBefore" : { "$numberInt" : "1" }, "numIndexesAfter" : { "$numberInt" : "2" }, "createdCollectionAutomatically" : true, "ok" : { "$numberInt" : "1" } } }, "ok" : { "$numberInt" : "1" } }
(1 row)

-- 80% of docs: only "b" (no "a" path -> excluded from the partial index).
SELECT COUNT(documentdb_api.insert_one('db', 'dpkpfe',
    format('{ "_id": %s, "b": %s }', i, i)::documentdb_core.bson))
FROM generate_series(1, 8000) AS i;
 count 
-------
  8000
(1 row)

-- 20% of docs: "a" present as an ARRAY (multikey) plus "b".
SELECT COUNT(documentdb_api.insert_one('db', 'dpkpfe',
    format('{ "_id": %s, "a": [%s, %s], "b": %s }',
           i, i % 10, (i + 1) % 10, i)::documentdb_core.bson))
FROM generate_series(8001, 10000) AS i;
 count 
-------
  2000
(1 row)

ANALYZE;
-- ------------------------------------------------------------
-- Assertion 2: with the distinct column constrained by the partial filter
-- expression, the partial index path row estimate is reduced exactly once
-- and stays in the same magnitude as the plain implicit-distinct index
-- path estimate.
--
-- The partial index carries only the ~20% of documents that contain "a",
-- so its statistics differ slightly from the plain index and the two
-- estimates are close but not exactly equal; an exact-equality check would
-- be brittle across environments. A double reduction, in contrast, applies
-- the sparse exists selectivity (~0.2) a second time and collapses the
-- estimate to roughly a fifth. We therefore require the partial-index
-- estimate to stay at least half of the plain implicit estimate.
--
-- Without the partial-filter fix the redundant "a >= MinKey" boundary is
-- injected on top of the partial-filter constraint, reducing the partial
-- index path a second time -> it collapses well below half the implicit
-- estimate -> FALSE. With the fix the injection is skipped -> TRUE.
-- ------------------------------------------------------------
SELECT pg_temp.distinct_index_rows('{ "distinct": "dpkpfe", "key": "a", "query": { "b": { "$gte": 1 }, "a": { "$exists": true } } }')
     >= pg_temp.distinct_index_rows('{ "distinct": "dpk", "key": "a", "query": { "b": { "$gte": 1 } } }') / 2
  AS partial_filter_index_not_double_reduced;
 partial_filter_index_not_double_reduced 
-----------------------------------------
 t
(1 row)

DROP FUNCTION pg_temp.distinct_index_rows(text);
