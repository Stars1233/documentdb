(1 row)

-- seq = ascending insert order (correlation ~ 1.0)
-- rnd = deterministic scramble via hashint4 (correlation ~ 0)
-- padding keeps rows wide so the index scan cost path is exercised.
SELECT COUNT(documentdb_api.insert_one('corr_idb', 'index_correlation',
    bson_build_document(
        '_id'::text, i,
        'seq'::text, i,
        'rnd'::text, (abs(hashint4(i)) % 100000),
        'tag'::text, (i % 10),
        'pad'::text, repeat('x', 1010))))
FROM generate_series(1, 10000) i;
 count 
-------
 10000
(1 row)

ANALYZE documentdb_data.documents_21201;
set documentdb.enableExplainScanIndexCosts to on;
set documentdb.enableExtendedExplainPlans to on;
-- Force the index-scan cost path: bitmap heap scans sort by page and report a
-- correlation of 0 regardless of statistics, so disable them here.
set enable_bitmapscan to off;
set enable_seqscan to off;
-- The correlated leading path (seq) should be reported as highly correlated.
SELECT index_correlation_tests.classify_index_correlation(
    $q$ EXPLAIN (COSTS OFF) SELECT document FROM bson_aggregation_find('corr_idb', '{ "find": "index_correlation", "filter": { "seq": { "$gte": 100, "$lte": 300 } }}') $q$,
    'seq_tag_1');
        classify_index_correlation        
------------------------------------------
 highly correlated (|correlation| >= 0.5)
(1 row)

-- The scrambled leading path (rnd) should be reported as uncorrelated.
SELECT index_correlation_tests.classify_index_correlation(
    $q$ EXPLAIN (COSTS OFF) SELECT document FROM bson_aggregation_find('corr_idb', '{ "find": "index_correlation", "filter": { "rnd": { "$gte": 100, "$lte": 2000 } }}') $q$,
    'rnd_tag_1');
     classify_index_correlation     
------------------------------------
 uncorrelated (|correlation| < 0.1)
(1 row)

-- With the statistics-based correlation feature flag disabled, the correlated
-- leading path falls back to the base access method estimate and is no longer
-- reported as highly correlated.
set documentdb.enable_index_correlation_from_statistics to off;
SELECT index_correlation_tests.classify_index_correlation(
    $q$ EXPLAIN (COSTS OFF) SELECT document FROM bson_aggregation_find('corr_idb', '{ "find": "index_correlation", "filter": { "seq": { "$gte": 100, "$lte": 300 } }}') $q$,
    'seq_tag_1');
     classify_index_correlation     
------------------------------------
 uncorrelated (|correlation| < 0.1)
(1 row)

reset documentdb.enable_index_correlation_from_statistics;
-- ============================================================================
-- Sort direction and descending (backward) index correlation.
--
-- The physical-order correlation reported to the planner tracks the direction
-- the index is actually scanned relative to the heap:
--   * An ascending index over an ascending-inserted leading path is scanned
--     forward and tracks physical order  -> positive (highly) correlated.
--   * A descending index over the same leading path is scanned forward in the
--     opposite direction of physical order -> negative (inversely) correlated.
--   * Adding an ORDER BY flips the scan direction: a descending index with a
--     matching descending sort is scanned backward and once again tracks
--     physical order -> positive; an ascending index with a descending sort is
--     scanned backward against physical order -> negative.
-- ============================================================================
-- A descending composite index over the same ascending-inserted leading path.
SELECT documentdb_api_internal.create_indexes_non_concurrently(
    'corr_idb', '{ "createIndexes": "index_correlation", "indexes": [ { "name": "seq_desc_tag_1", "key": { "seq": -1, "tag": 1 } } ] }', TRUE);
                                                                                                   create_indexes_non_concurrently                                                                                                    
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 { "raw" : { "defaultShard" : { "numIndexesBefore" : { "$numberInt" : "3" }, "numIndexesAfter" : { "$numberInt" : "4" }, "createdCollectionAutomatically" : false, "ok" : { "$numberInt" : "1" } } }, "ok" : { "$numberInt" : "1" } }
(1 row)

-- Signed classifier that preserves the sign of the correlation so ascending
-- (positive) and descending/inverted (negative) scans can be told apart.
CREATE FUNCTION index_correlation_tests.classify_signed_index_correlation(p_query text, p_index text) RETURNS text
 LANGUAGE plpgsql AS $$
DECLARE
    v_explain_row text;
    v_correlation numeric;
BEGIN
    FOR v_explain_row IN EXECUTE p_query
    LOOP
        IF v_explain_row LIKE '%' || p_index || '%' AND v_explain_row LIKE '%correlation=%' THEN
            v_correlation := substring(v_explain_row from 'correlation=([0-9.eE+-]+)')::numeric;
            IF v_correlation >= 0.5 THEN
                RETURN 'highly correlated (correlation >= 0.5)';
            ELSIF v_correlation <= -0.5 THEN
                RETURN 'inversely correlated (correlation <= -0.5)';
            ELSIF abs(v_correlation) < 0.1 THEN
                RETURN 'uncorrelated (|correlation| < 0.1)';
            ELSE
                RETURN 'moderately correlated (0.1 <= |correlation| < 0.5)';
            END IF;
        END IF;
    END LOOP;
    RETURN 'no cost line found for index ' || p_index;
END;
$$;
-- Ascending index, no sort: forward scan tracks physical order -> highly correlated.
SELECT index_correlation_tests.classify_signed_index_correlation(
    $q$ EXPLAIN (COSTS OFF) SELECT document FROM bson_aggregation_find('corr_idb', '{ "find": "index_correlation", "filter": { "seq": { "$gte": 100, "$lte": 300 } }, "hint": { "seq": 1, "tag": 1 } }') $q$,
    'seq_tag_1');
   classify_signed_index_correlation    
----------------------------------------
 highly correlated (correlation >= 0.5)
(1 row)

-- Descending index, no sort: forward scan runs opposite to physical order -> inversely correlated.
SELECT index_correlation_tests.classify_signed_index_correlation(
    $q$ EXPLAIN (COSTS OFF) SELECT document FROM bson_aggregation_find('corr_idb', '{ "find": "index_correlation", "filter": { "seq": { "$gte": 100, "$lte": 300 } }, "hint": { "seq": -1, "tag": 1 } }') $q$,
    'seq_desc_tag_1');
     classify_signed_index_correlation      
--------------------------------------------
 inversely correlated (correlation <= -0.5)
(1 row)

-- Descending index with a matching descending sort: the backward scan tracks
-- physical order again -> highly correlated.
SELECT index_correlation_tests.classify_signed_index_correlation(
    $q$ EXPLAIN (COSTS OFF) SELECT document FROM bson_aggregation_find('corr_idb', '{ "find": "index_correlation", "filter": { "seq": { "$gte": 100, "$lte": 300 } }, "sort": { "seq": -1 }, "hint": { "seq": -1, "tag": 1 } }') $q$,
    'seq_desc_tag_1');
   classify_signed_index_correlation    
----------------------------------------
 highly correlated (correlation >= 0.5)
(1 row)

-- Ascending index with a descending sort: the backward scan runs against
-- physical order -> inversely correlated.
SELECT index_correlation_tests.classify_signed_index_correlation(
    $q$ EXPLAIN (COSTS OFF) SELECT document FROM bson_aggregation_find('corr_idb', '{ "find": "index_correlation", "filter": { "seq": { "$gte": 100, "$lte": 300 } }, "sort": { "seq": -1 }, "hint": { "seq": 1, "tag": 1 } }') $q$,
    'seq_tag_1');
     classify_signed_index_correlation      
--------------------------------------------
 inversely correlated (correlation <= -0.5)
(1 row)

reset enable_bitmapscan;
reset enable_seqscan;
SELECT documentdb_api.drop_collection('corr_idb', 'index_correlation');
 drop_collection 
-----------------
 t
