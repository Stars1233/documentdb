-- One $elemMatch owns the leading bound, so all of its same-prefix quals stay
-- on the index. The cross-element decoy (_id:2) is rejected by the index.
SELECT documentdb_test_helpers.run_explain_and_trim($cmd$
    EXPLAIN (COSTS OFF, ANALYZE ON, SUMMARY OFF, TIMING OFF, BUFFERS OFF)
    SELECT document FROM bson_aggregation_find(
        'rct_prune_db',
        '{"find":"items","filter":{"items":{"$elemMatch":{"id":"A","city":"seattle"}}},"hint":"idx_items_profile"}')
$cmd$);
                                                                                                                                                                                                                    run_explain_and_trim
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Custom Scan (DocumentDBApiExplainQueryScan) (actual rows=2 loops=1)
   namespaceName: rct_prune_db.items
   indexName: idx_items_profile
   indexKey: {"items.id": 1,"items.city": 1,"items.role": 1,"profile.city": 1,"profile.age": 1}
   isMultiKey: true
   multiKeyPaths: items.id, items.city, items.role
   hasCorrelatedTerms: true
   indexBounds: ["items.id": ["A", "A"], "items.city": ["seattle", "seattle"], "items.role": (MinKey, MaxKey), "profile.city": (MinKey, MaxKey), "profile.age": (MinKey, MaxKey)]
   innerScanLoops: 3 loops
   scanType: ordered
   scanKeyDetails: key 1: [(isInequality: true, estimatedEntryCount: 2)]
   ->  Index Scan using idx_items_profile on documents_29201 collection (actual rows=2 loops=1)
         Index Cond: ((document @<> '{ "items.id" : { "elemMatchIndexOp" : [ { "op" : { "$numberInt" : "1" }, "value" : "A", "isTopLevel" : false, "hasMultiSegmentSubpath" : false, "rctBoundsPlanApplied" : true } ] } }'::bson) AND (document @<> '{ "items.city" : { "elemMatchIndexOp" : [ { "op" : { "$numberInt" : "1" }, "value" : "seattle", "isTopLevel" : false, "hasMultiSegmentSubpath" : false, "rctBoundsPlanApplied" : true } ] } }'::bson))
         Filter: (document @#? '{ "items" : { "id" : "A", "city" : "seattle" } }'::bson)
(14 rows)

SELECT document
FROM bson_aggregation_find(
    'rct_prune_db',
    '{"find":"items","filter":{"items":{"$elemMatch":{"id":"A","city":"seattle"}}},"sort":{"_id":1},"hint":"idx_items_profile"}');
                                                                                                    document
