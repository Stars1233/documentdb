SET search_path TO documentdb_api,documentdb_core,documentdb_api_catalog;
SET documentdb.next_collection_id TO 2100;
SET documentdb.next_collection_index_id TO 2100;
SET documentdb.defaultUseCompositeOpClass TO on;
SET documentdb_core.enableCollation TO on;
SET documentdb.enableCollationWithNonUniqueOrderedIndexes TO on;
-- set the rum fillfactor to 100
SET documentdb_rum.rum_default_page_fill_factor TO 100;
-- ===== Section 1: Padded non-collation index with fill factor 100 =====
-- Padded strings (item00001, item00002...) are monotonically increasing,
-- so fill factor 100 should be respected.
SELECT documentdb_api_internal.create_indexes_non_concurrently(
  'collff_db',
  '{
    "createIndexes": "collff_nocoll",
    "indexes": [{
      "key": { "c": 1, "a": 1 },
      "name": "a_nocoll_ff_idx"
    }]
  }',
  TRUE
);
NOTICE:  creating collection
                                                                                                   create_indexes_non_concurrently                                                                                                   
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 { "raw" : { "defaultShard" : { "numIndexesBefore" : { "$numberInt" : "1" }, "numIndexesAfter" : { "$numberInt" : "2" }, "createdCollectionAutomatically" : true, "ok" : { "$numberInt" : "1" } } }, "ok" : { "$numberInt" : "1" } }
(1 row)

-- insert 2000 docs with monotonically increasing "a" string values and padding in "c"
SELECT COUNT(documentdb_api.insert_one('collff_db', 'collff_nocoll',
    bson_build_document('_id', i, 'a', concat('item', lpad(i::text, 5, '0')), 'c', repeat('a', 1024))))
FROM generate_series(1, 2000) i;
 count 
-------
  2000
(1 row)

-- Collection ID layout (single db collff_db):
--   2100: db metadata
--   2101: collff_nocoll      -> pk 2101, rum index 2102
--   2102: collff_coll        -> pk 2103, rum index 2104
--   2103: collff_np_nocoll   -> pk 2105, rum index 2106
--   2104: collff_np_coll     -> pk 2107, rum index 2108
--   2105: collff_numeric     -> pk 2109, rum index 2110
\d documentdb_data.documents_2101
          Table "documentdb_data.documents_2101"
     Column      |  Type  | Collation | Nullable | Default 
-----------------+--------+-----------+----------+---------
 shard_key_value | bigint |           | not null | 
 object_id       | bson   |           | not null | 
 document        | bson   |           | not null | 
Indexes:
    "collection_pk_2101" PRIMARY KEY, btree (shard_key_value, object_id)
    "documents_rum_index_2102" documentdb_extended_rum (document documentdb_extended_rum_catalog.bson_extended_rum_composite_path_ops (pathspec='[ "c", "a" ]', tl='2691'))
Check constraints:
    "shard_key_value_check" CHECK (shard_key_value = '2101'::bigint)

VACUUM (FREEZE ON, INDEX_CLEANUP ON) documentdb_data.documents_2101;
-- exclude the rightmost leaf page since it may not be fully filled
WITH r1 AS (
    SELECT documentdb_api_internal.documentdb_rum_get_meta_page_info(
        public.get_raw_page('documentdb_data.documents_rum_index_2102', 0)
    )->>'totalPages' AS total_pages),
r2 AS (
    SELECT i AS page_num, documentdb_api_internal.documentdb_rum_page_get_stats(
        public.get_raw_page('documentdb_data.documents_rum_index_2102', i)
    ) AS page_stats
    FROM generate_series(1, (SELECT total_pages::int4 FROM r1) - 1) i),
r3 AS (
    SELECT page_num, page_stats FROM r2 WHERE page_stats->>'flagsStr' = 'LEAF')
SELECT CASE
    WHEN percentile_cont(0.5) WITHIN GROUP (ORDER BY (page_stats->>'nEntries')::int4) BETWEEN 90 AND 130
    THEN 'PASS: fill factor 100 respected without collation'
    ELSE 'FAIL: fill factor 100 NOT respected without collation - test invalid'
END AS fillfactor_check,
percentile_cont(0.5) WITHIN GROUP (ORDER BY (page_stats->>'nEntries')::int4) AS median_nentries
FROM r3
WHERE page_num < (SELECT MAX(page_num) FROM r3);
                 fillfactor_check                  | median_nentries 
---------------------------------------------------+-----------------
 PASS: fill factor 100 respected without collation |              97
(1 row)

-- verify reindex also keeps fill factor 100
SET maintenance_work_mem TO '1024';
REINDEX INDEX documentdb_data.documents_rum_index_2102;
WITH r1 AS (
    SELECT documentdb_api_internal.documentdb_rum_get_meta_page_info(
        public.get_raw_page('documentdb_data.documents_rum_index_2102', 0)
    )->>'totalPages' AS total_pages),
r2 AS (
    SELECT i AS page_num, documentdb_api_internal.documentdb_rum_page_get_stats(
        public.get_raw_page('documentdb_data.documents_rum_index_2102', i)
    ) AS page_stats
    FROM generate_series(1, (SELECT total_pages::int4 FROM r1) - 1) i),
r3 AS (
    SELECT page_num, page_stats FROM r2 WHERE page_stats->>'flagsStr' = 'LEAF')
SELECT CASE
    WHEN percentile_cont(0.5) WITHIN GROUP (ORDER BY (page_stats->>'nEntries')::int4) BETWEEN 90 AND 130
    THEN 'PASS: fill factor 100 respected without collation after reindex'
    ELSE 'FAIL: fill factor 100 NOT respected without collation after reindex - test invalid'
END AS fillfactor_check,
percentile_cont(0.5) WITHIN GROUP (ORDER BY (page_stats->>'nEntries')::int4) AS median_nentries
FROM r3
WHERE page_num < (SELECT MAX(page_num) FROM r3);
                        fillfactor_check                         | median_nentries 
-----------------------------------------------------------------+-----------------
 PASS: fill factor 100 respected without collation after reindex |              97
(1 row)

RESET maintenance_work_mem;
