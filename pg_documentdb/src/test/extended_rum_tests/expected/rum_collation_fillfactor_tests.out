-- verify that disabling fill factor causes it to drop for the collation index
SET documentdb_rum.enable_page_fill_factor TO off;
REINDEX INDEX documentdb_data.documents_rum_index_2104;
WITH r1 AS (
    SELECT documentdb_api_internal.documentdb_rum_get_meta_page_info(
        public.get_raw_page('documentdb_data.documents_rum_index_2104', 0)
    )->>'totalPages' AS total_pages),
r2 AS (
    SELECT i AS page_num, documentdb_api_internal.documentdb_rum_page_get_stats(
        public.get_raw_page('documentdb_data.documents_rum_index_2104', i)
    ) AS page_stats
    FROM generate_series(1, (SELECT total_pages::int4 FROM r1) - 1) i),
r3 AS (
    SELECT page_num, page_stats FROM r2 WHERE page_stats->>'flagsStr' = 'LEAF')
SELECT CASE
    WHEN percentile_cont(0.5) WITHIN GROUP (ORDER BY (page_stats->>'nEntries')::int4) BETWEEN 40 AND 65
    THEN 'PASS: fill factor dropped as expected when disabled'
    ELSE 'FAIL: fill factor did not drop when disabled - test invalid'
END AS fillfactor_check,
percentile_cont(0.5) WITHIN GROUP (ORDER BY (page_stats->>'nEntries')::int4) AS median_nentries
FROM r3
WHERE page_num < (SELECT MAX(page_num) FROM r3);
                  fillfactor_check                   | median_nentries 
-----------------------------------------------------+-----------------
 PASS: fill factor dropped as expected when disabled |              50
(1 row)

RESET documentdb_rum.enable_page_fill_factor;
RESET maintenance_work_mem;
-- ===== Section 3: Non-padded strings (non-monotonic sort order) =====
-- With unpadded strings (item1, item10, item2...) inserts are non-monotonic,
-- causing mid-tree page splits and lower fill factor on insert.
SET documentdb_rum.rum_default_page_fill_factor TO 100;
-- non-collation with non-padded string
SELECT documentdb_api_internal.create_indexes_non_concurrently(
  'collff_db',
  '{
    "createIndexes": "collff_np_nocoll",
    "indexes": [{
      "key": { "c": 1, "a": 1 },
      "name": "a_np_nocoll_ff_idx"
    }]
  }',
  TRUE
);
NOTICE:  creating collection
