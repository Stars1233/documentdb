-- ===== Section 5: Numeric collation - strings sorted numerically =====
-- With numericOrdering: true, string values "1","2"..."1000" sort numerically
-- (1 < 2 < 10 < 100), so inserts are monotonically increasing → fill factor ~100%.
-- With fill factor disabled, reindex produces ~50% fill factor.
SET documentdb_rum.rum_default_page_fill_factor TO 100;
SELECT documentdb_api_internal.create_indexes_non_concurrently(
  'collff_db',
  '{
    "createIndexes": "collff_numeric",
    "indexes": [{
      "key": { "c": 1, "a": 1 },
      "name": "a_numeric_coll_ff_idx",
      "collation": { "locale": "en", "numericOrdering": true }
    }]
  }',
  TRUE
);
NOTICE:  creating collection
