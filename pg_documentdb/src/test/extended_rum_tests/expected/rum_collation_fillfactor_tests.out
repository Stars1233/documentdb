-- verify reindex also keeps fill factor 100
SET maintenance_work_mem TO '1024';
REINDEX INDEX documentdb_data.documents_rum_index_2110;
WITH r1 AS (
    SELECT documentdb_api_internal.documentdb_rum_get_meta_page_info(
        public.get_raw_page('documentdb_data.documents_rum_index_2110', 0)
    )->>'totalPages' AS total_pages),
r2 AS (
    SELECT i AS page_num, documentdb_api_internal.documentdb_rum_page_get_stats(
        public.get_raw_page('documentdb_data.documents_rum_index_2110', i)
    ) AS page_stats
    FROM generate_series(1, (SELECT total_pages::int4 FROM r1) - 1) i),
r3 AS (
    SELECT page_num, page_stats FROM r2 WHERE page_stats->>'flagsStr' = 'LEAF')
SELECT CASE
    WHEN percentile_cont(0.5) WITHIN GROUP (ORDER BY (page_stats->>'nEntries')::int4) BETWEEN 90 AND 130
    THEN 'PASS: fill factor 100 respected with numeric collation after reindex'
    ELSE 'FAIL: fill factor 100 NOT respected with numeric collation after reindex - test invalid'
END AS fillfactor_check,
percentile_cont(0.5) WITHIN GROUP (ORDER BY (page_stats->>'nEntries')::int4) AS median_nentries
FROM r3
WHERE page_num < (SELECT MAX(page_num) FROM r3);
                           fillfactor_check                           | median_nentries 
----------------------------------------------------------------------+-----------------
 PASS: fill factor 100 respected with numeric collation after reindex |             107
(1 row)

-- verify that disabling fill factor causes it to drop
SET documentdb_rum.enable_page_fill_factor TO off;
REINDEX INDEX documentdb_data.documents_rum_index_2110;
WITH r1 AS (
    SELECT documentdb_api_internal.documentdb_rum_get_meta_page_info(
        public.get_raw_page('documentdb_data.documents_rum_index_2110', 0)
    )->>'totalPages' AS total_pages),
r2 AS (
    SELECT i AS page_num, documentdb_api_internal.documentdb_rum_page_get_stats(
        public.get_raw_page('documentdb_data.documents_rum_index_2110', i)
    ) AS page_stats
    FROM generate_series(1, (SELECT total_pages::int4 FROM r1) - 1) i),
r3 AS (
    SELECT page_num, page_stats FROM r2 WHERE page_stats->>'flagsStr' = 'LEAF')
SELECT CASE
    WHEN percentile_cont(0.5) WITHIN GROUP (ORDER BY (page_stats->>'nEntries')::int4) BETWEEN 40 AND 65
    THEN 'PASS: fill factor dropped as expected with numeric collation when disabled'
    ELSE 'FAIL: fill factor did not drop with numeric collation when disabled - test invalid'
END AS fillfactor_check,
percentile_cont(0.5) WITHIN GROUP (ORDER BY (page_stats->>'nEntries')::int4) AS median_nentries
FROM r3
WHERE page_num < (SELECT MAX(page_num) FROM r3);
                              fillfactor_check                              | median_nentries 
----------------------------------------------------------------------------+-----------------
 PASS: fill factor dropped as expected with numeric collation when disabled |              55
(1 row)

RESET documentdb_rum.enable_page_fill_factor;
-- verify that with fill factor 100 but compare function fmgr disabled,
-- inserts don't benefit from the optimized compare path → fill factor drops
SET documentdb_rum.rum_default_page_fill_factor TO 100;
SET documentdb_rum.enable_compare_function_fmgr TO off;
-- delete all docs and reinsert with fmgr disabled
SELECT documentdb_api.delete('collff_db', '{"delete": "collff_numeric", "deletes": [{"q": {}, "limit": 0}]}');
                                          delete                                           
-------------------------------------------------------------------------------------------
 ("{ ""n"" : { ""$numberInt"" : ""1000"" }, ""ok"" : { ""$numberDouble"" : ""1.0"" } }",t)
(1 row)

