 { "_id" : { "$numberInt" : "2" }, "a" : "cherry" }
 { "_id" : { "$numberInt" : "4" }, "a" : [ "apple", "cherry" ] }
 { "_id" : { "$numberInt" : "7" }, "a" : [ { "$numberInt" : "1" }, "cherry" ] }
 { "_id" : { "$numberInt" : "8" }, "a" : [  ] }
 { "_id" : { "$numberInt" : "9" }, "a" : null }
 { "_id" : { "$numberInt" : "10" }, "a" : "Cherry" }
(7 rows)

