 { "_id" : { "$numberInt" : "24" }, "a" : { "$numberInt" : "42" } }
 { "_id" : { "$numberInt" : "25" }, "a" : true }
 { "_id" : { "$numberInt" : "26" }, "a" : null }
 { "_id" : { "$numberInt" : "27" } }
(5 rows)

