SELECT document FROM bson_aggregation_pipeline('iosmk_db', '{ "aggregate" : "coll", "pipeline" : [{ "$match" : { "region": { "$in": [ "west", { "$regularExpression": { "pattern": "^s", "options": "" } } ] } } }, { "$sort" : { "_id": 1 } }, { "$project" : { "_id": 1 } }]}');
              document              
------------------------------------
 { "_id" : { "$numberInt" : "1" } }
 { "_id" : { "$numberInt" : "3" } }
 { "_id" : { "$numberInt" : "4" } }
(3 rows)

