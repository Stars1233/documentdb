 { "_id" : { "$numberInt" : "2" } }
 { "_id" : { "$numberInt" : "4" } }
 { "_id" : { "$numberInt" : "5" } }
 { "_id" : { "$numberInt" : "6" } }
 { "_id" : { "$numberInt" : "7" } }
(5 rows)

