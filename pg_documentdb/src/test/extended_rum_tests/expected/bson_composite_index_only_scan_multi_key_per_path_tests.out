         indexName: region_tags_1
         indexKey: {"region": 1,"tags": 1}
         isMultiKey: true
         multiKeyPaths: tags
         indexBounds: ["region": ["west", "west"], "tags": [MinKey, MaxKey]]
         innerScanLoops: 3 loops
         scanType: ordered
