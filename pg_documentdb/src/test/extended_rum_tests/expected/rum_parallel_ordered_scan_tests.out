-- ============================================================
-- Parallel ordered scan: backward walk with $gte/$gt
-- The $gte operator triggers a backward direction scan through
-- the RUM index, exercising the backward page walk in parallel.
-- ============================================================
-- Verify backward walk plan uses Index Scan on RUM index
EXPLAIN (COSTS OFF) SELECT document FROM bson_aggregation_find('pord_db',
    '{ "find": "ordered_scan", "filter": { "createdAt": { "$gte": { "$date": "2020-01-01T00:00:00Z" } } }, "sort": { "createdAt": -1 } }');
                                                         QUERY PLAN                                                          
-----------------------------------------------------------------------------------------------------------------------------
 Gather Merge
   Workers Planned: 2
   ->  Parallel Custom Scan (DocumentDBApiExplainQueryScan)
         namespaceName: pord_db.ordered_scan
         indexName: createdAt_1
         indexKey: {"createdAt": 1}
         isMultiKey: false
         indexBounds: ["createdAt": [{ "$date" : "2020-01-01T00:00:00Z" }, { "$date" : "292278994-08-17T07:12:55.807Z" }]]
         ->  Parallel Index Scan using "createdAt_1" on documents_20101 collection
               Index Cond: (document @>= '{ "createdAt" : { "$date" : { "$numberLong" : "1577836800000" } } }'::bson)
               Order By: (document OPERATOR(documentdb_api_internal.<>-|) '{ "createdAt" : { "$numberInt" : "-1" } }'::bson)
(11 rows)

