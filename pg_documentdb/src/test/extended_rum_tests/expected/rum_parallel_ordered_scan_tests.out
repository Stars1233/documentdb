SELECT documentdb_api.count_query('pord_db', '{ "count": "ordered_scan", "query": { "createdAt": { "$gte": { "$date": "2020-01-01T00:00:00Z" } } } }');
                               count_query                               
-------------------------------------------------------------------------
 { "n" : { "$numberInt" : "2500" }, "ok" : { "$numberDouble" : "1.0" } }
