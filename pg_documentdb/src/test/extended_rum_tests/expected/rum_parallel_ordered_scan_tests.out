-- ============================================================
-- Parallel ordered scan: distinct query
-- Exercises parallel index scan with distinct pushdown on the
-- createdAt field (10 distinct year values: 2015-2024).
-- ============================================================
SET documentdb.enableDistinctIndexPushdown TO on;
-- Verify distinct plan uses parallel scan on RUM index
EXPLAIN (COSTS OFF) SELECT document FROM bson_aggregation_distinct('pord_db',
    '{ "distinct": "ordered_scan", "key": "createdAt" }');
                                                           QUERY PLAN                                                            
---------------------------------------------------------------------------------------------------------------------------------
 Aggregate
   ->  Unique
         ->  Gather Merge
               Workers Planned: 2
               ->  ProjectSet
                     ->  Parallel Custom Scan (DocumentDBApiExplainQueryScan)
                           namespaceName: pord_db.ordered_scan
                           indexName: createdAt_1
                           indexKey: {"createdAt": 1}
                           isMultiKey: false
                           indexBounds: ["createdAt": (MinKey, MaxKey)]
                           ->  Parallel Index Only Scan using "createdAt_1" on documents_20101 collection
                                 Index Cond: (document @<> '{ "createdAt" : { "orderByScan" : { "$numberInt" : "1" } } }'::bson)
                                 Order By: (document |-<> '{ "createdAt" : { "$numberInt" : "1" } }'::bson)
(14 rows)

