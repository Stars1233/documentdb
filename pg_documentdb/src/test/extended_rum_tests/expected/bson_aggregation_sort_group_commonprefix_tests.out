EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('db',
    '{ "aggregate": "cpfx_test", "pipeline": [
        { "$sort": { "a": 1, "b": 1 } },
        { "$group": { "_id": { "a": "$a", "r": "$$ROOT" }, "firstVal": { "$first": "$name" } } }
    ], "cursor": {}, "hint": "idx_a_b" }');
                                                                                                                                                                                                                                                                                                                                    QUERY PLAN                                                                                                                                                                                                                                                                                                                                    
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 GroupAggregate
   Output: bson_repath_and_build('_id'::text, (bson_expression_get(agg_stage_0.document, '{ "" : { "a" : "$a", "r" : "$$ROOT" } }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), 'firstVal'::text, bson_expression_get(bsonfirst(agg_stage_0.document, '{"{ \"a\" : { \"$numberInt\" : \"1\" } }","{ \"b\" : { \"$numberInt\" : \"1\" } }"}'::bson[]), '{ "" : "$name" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), (bson_expression_get(agg_stage_0.document, '{ "" : { "a" : "$a", "r" : "$$ROOT" } }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))
   Group Key: (bson_expression_get(agg_stage_0.document, '{ "" : { "a" : "$a", "r" : "$$ROOT" } }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))
