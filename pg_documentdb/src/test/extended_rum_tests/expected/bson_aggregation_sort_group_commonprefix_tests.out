 { "_id" : { "a" : "A", "b" : "X" }, "firstVal" : "name_6" }
 { "_id" : { "a" : "A", "b" : "Y" }, "firstVal" : "name_3" }
 { "_id" : { "a" : "C", "b" : "X" }, "firstVal" : "name_2" }
 { "_id" : { "a" : "B", "b" : "X" }, "firstVal" : "name_4" }
 { "_id" : { "a" : "C", "b" : "Y" }, "firstVal" : "name_5" }
