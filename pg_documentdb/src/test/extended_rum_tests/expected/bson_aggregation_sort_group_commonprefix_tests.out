EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('db',
    '{ "aggregate": "cpfx_test", "pipeline": [
        { "$sort": { "a": 1, "b": 1 } },
        { "$group": { "_id": "$$ROOT", "firstVal": { "$first": "$name" } } }
    ], "cursor": {}, "hint": "idx_a_b" }');
                                                                                                                                                                                                                                                                                                              QUERY PLAN                                                                                                                                                                                                                                                                                                              
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 GroupAggregate
   Output: bson_repath_and_build('_id'::text, (bson_expression_get(agg_stage_0.document, '{ "" : "$$ROOT" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), 'firstVal'::text, bson_expression_get(bsonfirst(agg_stage_0.document, '{"{ \"a\" : { \"$numberInt\" : \"1\" } }","{ \"b\" : { \"$numberInt\" : \"1\" } }"}'::bson[]), '{ "" : "$name" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), (bson_expression_get(agg_stage_0.document, '{ "" : "$$ROOT" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))
   Group Key: (bson_expression_get(agg_stage_0.document, '{ "" : "$$ROOT" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))
   ->  Sort
         Output: (bson_expression_get(agg_stage_0.document, '{ "" : "$$ROOT" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), agg_stage_0.document
         Sort Key: (bson_expression_get(agg_stage_0.document, '{ "" : "$$ROOT" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))
         ->  Subquery Scan on agg_stage_0
               Output: bson_expression_get(agg_stage_0.document, '{ "" : "$$ROOT" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson), agg_stage_0.document
               ->  Index Scan using idx_a_b on documentdb_data.documents_9300 collection
                     Output: collection.document, bson_orderby(collection.document, '{ "a" : { "$numberInt" : "1" } }'::bson), bson_orderby(collection.document, '{ "b" : { "$numberInt" : "1" } }'::bson)
                     Index Cond: ((collection.document @<> '{ "a" : { "orderByScan" : { "$numberInt" : "1" } } }'::bson) AND (collection.document @<> '{ "b" : { "orderByScan" : { "$numberInt" : "1" } } }'::bson))
                     Order By: ((collection.document |-<> '{ "a" : { "$numberInt" : "1" } }'::bson) AND (collection.document |-<> '{ "b" : { "$numberInt" : "1" } }'::bson))
