-- ============================================================
-- Test 17: EXPLAIN distinct on truncated strings - pushdown ON
-- Should show index ordering with recheck for truncated terms
-- ============================================================
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableDistinctIndexPushdown TO on;
SELECT documentdb_test_helpers.run_explain_and_trim($cmd$
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_distinct('db', '{ "distinct": "dist_trunc", "key": "bigstr" }')
$cmd$);
                                                    run_explain_and_trim                                                     
-----------------------------------------------------------------------------------------------------------------------------
 Aggregate
   Output: bson_distinct_agg((bson_distinct_unwind(collection.document, 'bigstr'::text)))
   ->  Unique
         Output: (bson_distinct_unwind(collection.document, 'bigstr'::text))
         ->  ProjectSet
               Output: bson_distinct_unwind(collection.document, 'bigstr'::text)
               ->  Index Scan using idx_bigstr on documentdb_data.documents_19902 collection
                     Output: collection.shard_key_value, collection.object_id, collection.document
                     Index Cond: (collection.document @<> '{ "bigstr" : { "orderByScan" : { "$numberInt" : "1" } } }'::bson)
                     Order By: (collection.document |-<> '{ "bigstr" : { "$numberInt" : "1" } }'::bson)
(10 rows)

