EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_distinct('db', '{ "distinct": "dist_push", "key": "b" }')
$cmd$);
                                          run_explain_and_trim                                           
---------------------------------------------------------------------------------------------------------
