-- ============================================================
-- Test 14: EXPLAIN distinct with filter on indexed field - pushdown ON
-- ============================================================
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableDistinctIndexPushdown TO on;
SELECT documentdb_test_helpers.run_explain_and_trim($cmd$
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_distinct('db', '{ "distinct": "dist_push", "key": "a", "query": { "a": { "$gte": 5 } } }')
$cmd$);
                                           run_explain_and_trim                                           
----------------------------------------------------------------------------------------------------------
 Aggregate
   Output: bson_distinct_agg((bson_distinct_unwind(collection.document, 'a'::text)))
   ->  Unique
         Output: (bson_distinct_unwind(collection.document, 'a'::text))
         ->  Sort
               Output: (bson_distinct_unwind(collection.document, 'a'::text))
               Sort Key: (bson_distinct_unwind(collection.document, 'a'::text))
               ->  ProjectSet
                     Output: bson_distinct_unwind(collection.document, 'a'::text)
                     ->  Index Scan using idx_a on documentdb_data.documents_19900 collection
                           Output: collection.shard_key_value, collection.object_id, collection.document
                           Index Cond: (collection.document @>= '{ "a" : { "$numberInt" : "5" } }'::bson)
(12 rows)

ROLLBACK;
