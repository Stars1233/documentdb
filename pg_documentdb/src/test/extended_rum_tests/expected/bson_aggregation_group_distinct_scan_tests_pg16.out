-- Case 10: $lookup BEFORE $group. The join can multiply rows
-- per base document, so skipping duplicate TIDs on the base
-- relation would silently drop joined rows from later stages.
-- (Self-lookup on x for simplicity.)
-- ------------------------------------------------------------
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableGroupByDistinctScan TO on;
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist", "hint": "idx_x", "pipeline": [
    { "$lookup": { "from": "grp_dist", "as": "m", "localField": "x", "foreignField": "x" } },
    { "$group": { "_id": "$x" } },
    { "$sort": { "_id": 1 } }
  ] }');
