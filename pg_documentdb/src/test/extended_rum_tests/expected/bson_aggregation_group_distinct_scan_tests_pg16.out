-- ------------------------------------------------------------
-- Case 4: $project that selects only the indexed field, then
-- $group on it. Even this "pass-through" shape interposes a
-- bson_dollar_project() call, so the group key becomes a
-- function of the projected document rather than a direct Var
-- on the indexed column. Distinct-index pushdown does not
-- apply and the wrapper must not fire.
-- ------------------------------------------------------------
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableGroupByDistinctScan TO on;
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist", "hint": "idx_x", "pipeline": [
    { "$project": { "x": 1, "_id": 0 } },
    { "$group": { "_id": "$x" } },
    { "$sort": { "_id": 1 } }
  ] }');
    document     
-----------------
 { "_id" : "a" }
 { "_id" : "b" }
 { "_id" : "c" }
(3 rows)

