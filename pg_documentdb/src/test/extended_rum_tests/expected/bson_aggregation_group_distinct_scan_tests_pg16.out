-- ------------------------------------------------------------
-- Case 7a: $sort + $skip BEFORE $group. $skip is positionally
-- dependent on input row order; if the wrapper collapsed
-- duplicate TIDs first, "skip the first 2 rows" would silently
-- become "skip the first 2 distinct keys" -- a different
-- result. The leading $sort here pins the row order so the
-- skip semantics are deterministic.
-- ------------------------------------------------------------
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableGroupByDistinctScan TO on;
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist", "hint": "idx_x", "pipeline": [
    { "$sort": { "_id": 1 } },
    { "$skip": 2 },
    { "$group": { "_id": "$x" } },
    { "$sort": { "_id": 1 } }
  ] }');
    document     
-----------------
 { "_id" : "a" }
 { "_id" : "b" }
 { "_id" : "c" }
(3 rows)

