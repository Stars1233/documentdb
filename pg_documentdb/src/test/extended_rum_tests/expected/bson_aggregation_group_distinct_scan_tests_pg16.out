-- ============================================================
-- Section 4: Downstream stages (positive). Stages AFTER $group
-- operate on already-grouped rows, so they cannot affect the
-- correctness of per-key TID skipping. The wrapper should still
-- fire on the inner $group scan.
-- ============================================================
-- ------------------------------------------------------------
-- Case 12: $skip AFTER $group. Operates on the 3 group rows.
-- ------------------------------------------------------------
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableGroupByDistinctScan TO on;
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist", "hint": "idx_x", "pipeline": [
    { "$group": { "_id": "$x" } },
    { "$sort": { "_id": 1 } },
    { "$skip": 1 }
  ] }');
