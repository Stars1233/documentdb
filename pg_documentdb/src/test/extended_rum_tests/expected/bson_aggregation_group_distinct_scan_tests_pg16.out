-- ------------------------------------------------------------
-- Case 7b: bare $skip BEFORE $group (no preceding $sort).
-- This is the shape where the gate is most tempted to fire:
-- IndexScan -> Skip -> Group on the indexed key, with no
-- intervening Sort node confounding the plan. The wrapper
-- must still NOT fire, because key-skipping would silently
-- turn "skip 2 input rows" into "skip 2 distinct keys".
-- Paired with Case 7a, the leading-sort variant is exercised
-- as well so we cover both planner shapes.
-- ------------------------------------------------------------
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableGroupByDistinctScan TO on;
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist", "hint": "idx_x", "pipeline": [
    { "$skip": 2 },
    { "$group": { "_id": "$x" } },
    { "$sort": { "_id": 1 } }
  ] }');
    document     
-----------------
 { "_id" : "a" }
 { "_id" : "b" }
 { "_id" : "c" }
(3 rows)

