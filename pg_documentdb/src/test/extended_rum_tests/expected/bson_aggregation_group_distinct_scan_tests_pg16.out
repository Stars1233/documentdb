ANALYZE;
-- ============================================================
-- Test 1: $group with only _id (no accumulators) - GUC OFF
-- This is equivalent to SELECT DISTINCT on the group key.
-- With the GUC off, the plan should NOT show
-- DocumentDBApiDistinctQueryScan.
-- ============================================================
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableGroupByDistinctScan TO off;
-- Correctness: verify returned distinct values
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist", "hint": "idx_x", "pipeline": [
    { "$group": { "_id": "$x" } },
    { "$sort": { "_id": 1 } }
  ] }');
    document     
-----------------
 { "_id" : "a" }
 { "_id" : "b" }
 { "_id" : "c" }
(3 rows)

-- EXPLAIN ANALYZE: should NOT have DocumentDBApiDistinctQueryScan.
-- Without the custom scan, the index scan returns one row per document (8),
-- which the GroupAggregate then collapses to 3 groups.
SELECT documentdb_test_helpers.run_explain_and_trim($Q$
EXPLAIN (ANALYZE ON, COSTS OFF, BUFFERS OFF, SUMMARY OFF, TIMING OFF, VERBOSE ON)
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist", "hint": "idx_x", "pipeline": [
    { "$group": { "_id": "$x" } },
    { "$sort": { "_id": 1 } }
  ] }')
$Q$, p_ignore_heap_fetches := true);
                                                                                                                                                                   run_explain_and_trim                                                                                                                                                                   
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Sort (actual rows=3 loops=1)
   Output: agg_stage_1.document, (bson_orderby(agg_stage_1.document, '{ "_id" : { "$numberInt" : "1" } }'::bson))
   Sort Key: (bson_orderby(agg_stage_1.document, '{ "_id" : { "$numberInt" : "1" } }'::bson)) NULLS FIRST
   Sort Method: quicksort  Memory: xxxkB
   ->  Subquery Scan on agg_stage_1 (actual rows=3 loops=1)
         Output: agg_stage_1.document, bson_orderby(agg_stage_1.document, '{ "_id" : { "$numberInt" : "1" } }'::bson)
         ->  GroupAggregate (actual rows=3 loops=1)
               Output: bson_repath_and_build('_id'::text, (bson_expression_get(collection.document, '{ "" : "$x" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))), (bson_expression_get(collection.document, '{ "" : "$x" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))
               Group Key: bson_expression_get(collection.document, '{ "" : "$x" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)
               ->  Index Only Scan using idx_x on documentdb_data.documents_20000 collection (actual rows=8 loops=1)
                     Output: bson_expression_get(collection.document, '{ "" : "$x" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson), collection.document
                     Index Cond: (collection.document @<> '{ "x" : { "orderByScan" : { "$numberInt" : "1" } } }'::bson)
                     Order By: (collection.document |-<> '{ "x" : { "$numberInt" : "1" } }'::bson)
                     Heap Fetches: xxx
(14 rows)

ROLLBACK;
-- ============================================================
-- Test 2: $group with only _id (no accumulators) - GUC ON
-- With the GUC on, the plan SHOULD show
-- DocumentDBApiDistinctQueryScan wrapping the index scan.
-- ============================================================
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableGroupByDistinctScan TO on;
-- Correctness: same distinct values as Test 1
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist", "hint": "idx_x", "pipeline": [
    { "$group": { "_id": "$x" } },
    { "$sort": { "_id": 1 } }
  ] }');
    document     
-----------------
 { "_id" : "a" }
 { "_id" : "b" }
 { "_id" : "c" }
(3 rows)

-- EXPLAIN ANALYZE: should show DocumentDBApiDistinctQueryScan wrapping the
-- index scan. With the custom scan skipping duplicate TIDs, the index scan
-- node should emit one row per distinct key value (3), not one per document (8).
SELECT documentdb_test_helpers.run_explain_and_trim($Q$
EXPLAIN (ANALYZE ON, COSTS OFF, BUFFERS OFF, SUMMARY OFF, TIMING OFF, VERBOSE ON)
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist", "hint": "idx_x", "pipeline": [
    { "$group": { "_id": "$x" } },
    { "$sort": { "_id": 1 } }
  ] }')
$Q$, p_ignore_heap_fetches := true);
