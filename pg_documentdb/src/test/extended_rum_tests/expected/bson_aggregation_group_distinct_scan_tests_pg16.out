-- ------------------------------------------------------------
-- Case 15b: $match before a COMPOUND $group on the composite
-- index. Same Filter-before-key-skip invariant as 15a, but
-- exercises the multi-field gate path: the decomposed
-- group-by has to line up TWO indexorderbys with
-- group_pathkeys at the same time the residual Filter is
-- attached above the Index Scan. The filter is on _id, which
-- is not a key of idx_xy_composite, so it must stay a heap
-- Filter and cannot fold into an Index Cond. Pinning
-- Rows Removed by Filter > 0 catches a regression where the
-- wrapper key-skips before the predicate runs on the
-- compound-key path. Expect 5 distinct (x,y) tuples.
-- ------------------------------------------------------------
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableGroupByDistinctScan TO on;
SET LOCAL documentdb.enableGroupByCompoundIdIndexPushdown TO on;
SET LOCAL documentdb_core.enableWriteDocumentsInRepath TO on;
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist_more", "hint": "idx_xy_composite", "pipeline": [
    { "$match": { "_id": { "$gt": 3 } } },
    { "$group": { "_id": { "x": "$x", "y": "$y" } } },
    { "$sort": { "_id": 1 } }
  ] }');
                         document                         
----------------------------------------------------------
 { "_id" : { "x" : "a", "y" : { "$numberInt" : "60" } } }
 { "_id" : { "x" : "b", "y" : { "$numberInt" : "50" } } }
 { "_id" : { "x" : "b", "y" : { "$numberInt" : "80" } } }
 { "_id" : { "x" : "c", "y" : { "$numberInt" : "40" } } }
 { "_id" : { "x" : "c", "y" : { "$numberInt" : "70" } } }
(5 rows)

