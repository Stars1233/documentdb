-- ------------------------------------------------------------
-- Case 2: $sort BEFORE $group with $first accumulator.
-- $first depends on input order, so a distinct scan that skips
-- TIDs would return the wrong document per group. Blocked by
-- the accumulator gate; this pins that behavior end-to-end.
-- ------------------------------------------------------------
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableGroupByDistinctScan TO on;
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist", "hint": "idx_x", "pipeline": [
    { "$sort": { "y": 1 } },
    { "$group": { "_id": "$x", "f": { "$first": "$y" } } },
    { "$sort": { "_id": 1 } }
  ] }');
