-- ------------------------------------------------------------
-- Case 15a: $match pushed before single-field $group as a
-- base-rel WHERE. Wrapper fires; the index-scan Filter must
-- run per heap tuple before any key-skip. Pinning
-- Rows Removed by Filter > 0 catches a silent data-loss
-- regression if the wrapper ever key-skips before the
-- predicate. Index is keyed on x; filter on the non-key
-- field y so the predicate stays a residual heap Filter and
-- cannot fold into an Index Cond. Expect {a,b,c}.
-- ------------------------------------------------------------
BEGIN;
SET LOCAL enable_seqscan TO off;
SET LOCAL enable_bitmapscan TO off;
SET LOCAL enable_hashagg TO off;
SET LOCAL documentdb.enableGroupByDistinctScan TO on;
SELECT document FROM bson_aggregation_pipeline('db',
  '{ "aggregate": "grp_dist_more", "hint": "idx_x", "pipeline": [
    { "$match": { "y": { "$gt": 50 } } },
    { "$group": { "_id": "$x" } },
    { "$sort": { "_id": 1 } }
  ] }');
