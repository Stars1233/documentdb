-- Plan: $match on _id + $sample - verifies bson_dollar_range marker qual is stripped from IndexScan filter
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('reservoirdb', '{ "aggregate": "reservoirTest", "pipeline": [ { "$match": { "_id": { "$gt": 1, "$lte": 15 } } }, { "$sample": { "size": 3 } } ] }');
                                                                                                                                                                                      QUERY PLAN                                                                                                                                                                                      
--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Custom Scan (DocumentDBApiReservoirSample)
   Output: document
   Sample Size: 3
   ->  Index Scan using _id_ on documentdb_data.documents_25712001 collection
         Output: document
         Index Cond: ((collection.shard_key_value = '25712001'::bigint) AND (collection.object_id > '{ "" : { "$numberInt" : "1" } }'::bson) AND (collection.object_id <= '{ "" : { "$numberDouble" : "Infinity" } }'::bson) AND (collection.object_id <= '{ "" : { "$numberInt" : "15" } }'::bson) AND (collection.object_id >= '{ "" : { "$numberDouble" : "-Infinity" } }'::bson))
(6 rows)

