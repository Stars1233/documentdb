-- =============================================================================
-- BASELINE TESTS (Reservoir Sampling DISABLED - default ORDER BY random() LIMIT)
-- =============================================================================
SET documentdb.enableDollarSampleReservoirScan TO off;
-- Plan: $sample alone - should show Limit + Sort(random()) over TABLESAMPLE
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('reservoirdb', '{ "aggregate": "reservoirTest", "pipeline": [ { "$sample": { "size": 3 } } ] }');
                                QUERY PLAN                                
--------------------------------------------------------------------------
 Limit
   Output: document, (random())
   ->  Sort
         Output: document, (random())
         Sort Key: (random())
         ->  Sample Scan on documentdb_data.documents_25712001 collection
               Output: document, random()
               Sampling: system_rows ('3'::bigint)
(8 rows)

-- Plan: $match + $sample + $project + $sort (typical Spark partitioner shape)
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('reservoirdb', '{ "aggregate": "reservoirTest", "pipeline": [ { "$match": { "category": "A" } }, { "$sample": { "size": 3 } }, { "$project": { "_id": 1 } }, { "$sort": { "_id": 1 } } ] }');
                                                                                                                                                                                              QUERY PLAN                                                                                                                                                                                              
------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Sort
   Output: (bson_dollar_project(agg_stage_2.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson)), (bson_orderby(bson_dollar_project(agg_stage_2.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson), '{ "_id" : { "$numberInt" : "1" } }'::bson))
   Sort Key: (bson_orderby(bson_dollar_project(agg_stage_2.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson), '{ "_id" : { "$numberInt" : "1" } }'::bson)) NULLS FIRST
   ->  Subquery Scan on agg_stage_2
         Output: bson_dollar_project(agg_stage_2.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson), bson_orderby(bson_dollar_project(agg_stage_2.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson), '{ "_id" : { "$numberInt" : "1" } }'::bson)
         ->  Limit
               Output: collection.document, (random())
               ->  Sort
                     Output: collection.document, (random())
                     Sort Key: (random())
                     ->  Bitmap Heap Scan on documentdb_data.documents_25712001 collection
                           Output: collection.document, random()
                           Recheck Cond: (collection.shard_key_value = '25712001'::bigint)
                           Filter: (collection.document @= '{ "category" : "A" }'::bson)
                           ->  Bitmap Index Scan on _id_
                                 Index Cond: (collection.shard_key_value = '25712001'::bigint)
(16 rows)

-- Plan: empty $match + $sample
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('reservoirdb', '{ "aggregate": "reservoirTest", "pipeline": [ { "$match": {} }, { "$sample": { "size": 5 } } ] }');
                                QUERY PLAN                                
--------------------------------------------------------------------------
 Limit
   Output: document, (random())
   ->  Sort
         Output: document, (random())
         Sort Key: (random())
         ->  Sample Scan on documentdb_data.documents_25712001 collection
               Output: document, random()
               Sampling: system_rows ('5'::bigint)
(8 rows)

-- Plan: $sample + $match (filter after sampling)
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('reservoirdb', '{ "aggregate": "reservoirTest", "pipeline": [ { "$sample": { "size": 10 } }, { "$match": { "value": { "$gt": 100 } } } ] }');
                                       QUERY PLAN                                        
-----------------------------------------------------------------------------------------
 Subquery Scan on agg_stage_1
   Output: agg_stage_1.document
   Filter: (agg_stage_1.document #> '{ "value" : { "$numberInt" : "100" } }'::bsonquery)
   ->  Limit
         Output: collection.document, (random())
         ->  Sort
               Output: collection.document, (random())
               Sort Key: (random())
               ->  Sample Scan on documentdb_data.documents_25712001 collection
                     Output: collection.document, random()
                     Sampling: system_rows ('10'::bigint)
(11 rows)

RESET documentdb.enableDollarSampleReservoirScan;
-- =============================================================================
-- RESERVOIR SAMPLING ENABLED TESTS (CustomScan ReservoirSample)
-- These tests run with the default (ON) setting.
-- =============================================================================
-- Plan: $sample alone - uses TABLESAMPLE path (no filter = efficient already), no ReservoirSample needed
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('reservoirdb', '{ "aggregate": "reservoirTest", "pipeline": [ { "$sample": { "size": 3 } } ] }');
                                QUERY PLAN                                
--------------------------------------------------------------------------
 Limit
   Output: document, (random())
   ->  Sort
         Output: document, (random())
         Sort Key: (random())
         ->  Sample Scan on documentdb_data.documents_25712001 collection
               Output: document, random()
               Sampling: system_rows ('3'::bigint)
(8 rows)

-- Plan: $match + $sample + $project + $sort - ReservoirSample wraps the filtered base scan
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('reservoirdb', '{ "aggregate": "reservoirTest", "pipeline": [ { "$match": { "category": "A" } }, { "$sample": { "size": 3 } }, { "$project": { "_id": 1 } }, { "$sort": { "_id": 1 } } ] }');
                                                                                                                                                                                             QUERY PLAN                                                                                                                                                                                             
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Sort
   Output: (bson_dollar_project(collection.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson)), (bson_orderby(bson_dollar_project(collection.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson), '{ "_id" : { "$numberInt" : "1" } }'::bson))
   Sort Key: (bson_orderby(bson_dollar_project(collection.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson), '{ "_id" : { "$numberInt" : "1" } }'::bson)) NULLS FIRST
   ->  Custom Scan (DocumentDBApiReservoirSample)
         Output: bson_dollar_project(collection.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson), bson_orderby(bson_dollar_project(collection.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson), '{ "_id" : { "$numberInt" : "1" } }'::bson)
         Sample Size: 3
         ->  Bitmap Heap Scan on documentdb_data.documents_25712001 collection
               Output: collection.document
               Recheck Cond: (collection.shard_key_value = '25712001'::bigint)
               Filter: (collection.document @= '{ "category" : "A" }'::bson)
               ->  Bitmap Index Scan on _id_
                     Index Cond: (collection.shard_key_value = '25712001'::bigint)
(12 rows)

