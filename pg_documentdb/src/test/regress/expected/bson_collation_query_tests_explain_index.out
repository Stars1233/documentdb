-- ======================================================================
-- SECTION 2: Aggregation on arrays with collation
-- ======================================================================
-- (6.B)
SELECT documentdb_test_helpers.run_explain_and_trim($cmd$
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('coll_q_db', '{ "aggregate": "coll_array_filter", "pipeline": [ { "$sort": { "_id": 1 } }, { "$addFields": { "e": {  "f": "$a" } } }, { "$replaceRoot": { "newRoot": "$e" } }, { "$match" : { "f": { "$elemMatch": {"$eq": "cAt"} } } }, {"$project": { "items" : { "$filter" : { "input" : "$f", "as" : "animal", "cond" : { "$eq" : ["$$animal", "CAT"] } }} }} ],
 "cursor": {}, "collation": { "locale": "en", "strength" : 1} }')
$cmd$);
                                                                                                                                                                                                                                                                                                                                                                              run_explain_and_trim                                                                                                                                                                                                                                                                                                                                                                               
---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Sort
   Output: (documentdb_api_internal.bson_dollar_project(documentdb_api_internal.bson_dollar_replace_root(documentdb_api_internal.bson_dollar_add_fields(document, '{ "e" : { "f" : "$a" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson, 'en-u-ks-level1'::text), '{ "newRoot" : "$e" }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson, 'en-u-ks-level1'::text), '{ "items" : { "$filter" : { "input" : "$f", "as" : "animal", "cond" : { "$eq" : [ "$$animal", "CAT" ] } } } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson, 'en-u-ks-level1'::text)), (documentdb_api_internal.bson_orderby(document, '{ "_id" : { "$numberInt" : "1" } }'::bson, 'en-u-ks-level1'::text))
   Sort Key: (documentdb_api_internal.bson_orderby(collection.document, '{ "_id" : { "$numberInt" : "1" } }'::bson, 'en-u-ks-level1'::text)) USING <<< NULLS FIRST
   ->  Custom Scan (DocumentDBApiExplainQueryScan)
         Output: documentdb_api_internal.bson_dollar_project(documentdb_api_internal.bson_dollar_replace_root(documentdb_api_internal.bson_dollar_add_fields(document, '{ "e" : { "f" : "$a" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson, 'en-u-ks-level1'::text), '{ "newRoot" : "$e" }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson, 'en-u-ks-level1'::text), '{ "items" : { "$filter" : { "input" : "$f", "as" : "animal", "cond" : { "$eq" : [ "$$animal", "CAT" ] } } } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson, 'en-u-ks-level1'::text), documentdb_api_internal.bson_orderby(document, '{ "_id" : { "$numberInt" : "1" } }'::bson, 'en-u-ks-level1'::text)
         namespaceName: coll_q_db.coll_array_filter
         indexName: _id_
         ->  Bitmap Heap Scan on documentdb_data.documents_8800 collection
               Output: document
               Recheck Cond: (collection.shard_key_value = '8800'::bigint)
               Filter: (documentdb_api_internal.bson_dollar_replace_root(documentdb_api_internal.bson_dollar_add_fields(collection.document, '{ "e" : { "f" : "$a" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson, 'en-u-ks-level1'::text), '{ "newRoot" : "$e" }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson, 'en-u-ks-level1'::text) @#? '{ "f" : { "$eq" : "cAt" }, "collation" : "en-u-ks-level1" }'::bson)
               ->  Bitmap Index Scan on _id_
                     Index Cond: (collection.shard_key_value = '8800'::bigint)
