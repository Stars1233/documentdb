    EXPLAIN (COSTS OFF, ANALYZE ON, SUMMARY OFF, TIMING OFF, BUFFERS OFF)
    SELECT document FROM bson_aggregation_find('regexIdDb',
        '{ "find": "regex_id_big", "filter": { "_id": { "$regex": "^abc" } } }')
$cmd$);
