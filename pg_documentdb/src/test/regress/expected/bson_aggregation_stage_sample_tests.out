-- Decimal128 uses round-half-to-even: 3.5 -> 4
SELECT COUNT(*) FROM (SELECT document FROM bson_aggregation_pipeline('sampledb', '{ "aggregate": "samplePlanTest", "pipeline": [ { "$sample": { "size": { "$numberDecimal": "3.5" } } } ] }')) q;
