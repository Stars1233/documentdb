-- $push with $each and $slice: 0 on an empty array stays empty (result equals source, no-op)
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": []}', '{ "": { "$push" : {"a": { "$each" : [1,2], "$slice": 0 }} } }', '{}', NULL, NULL, NULL) as update_bson_document;
 update_bson_document 
----------------------
 
