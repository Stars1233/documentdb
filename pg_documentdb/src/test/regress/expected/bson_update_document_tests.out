-- update: Error cases:
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": { "b": [1, 2, 3 ]} }', '{ "": { "$set": { "a.b.7": 9, "a.b.10": 13 }, "$unset": { "a.b.7": 1 } } }', '{}', NULL, NULL, NULL);
ERROR:  Modifying the path 'a.b.7' will result in a conflict occurring at 'a.b.7'
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [ { "b": 2 } ] }', '{ "": { "$rename": { "a.0": "b" } } }', '{}', NULL, NULL, NULL);
ERROR:  The source field of a rename cannot be an array element
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [ { "b": 2 } ] }', '{ "": { "$rename": { "a.0.b": "a.1.c" } } }', '{}', NULL, NULL, NULL);
ERROR:  The source field of a rename cannot be an array element
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": { "$set": { "a": 2, "h": 6 } } }', '{ "_id": { "$eq": 1 }, "c": 3, "$and": [ { "c": 4 } ] }', NULL, NULL, NULL);
ERROR:  Unable to determine which query fields to set, as the path 'c' has been matched twice
SELECT documentdb_api_internal.update_bson_document('{"a": [1], "b": {"c": [2]}, "d": [{"e": 3}], "f": 4}', '{ "": { "$rename" :{"f":"d.e"}} }', '{}', NULL, NULL, NULL);
ERROR:  Invalid array index path e
SELECT documentdb_api_internal.update_bson_document('{"a": [1], "b": {"c": [2]}, "d": [{"e": 3}], "f": 4}', '{ "": { "$rename" :{"f":"d.e"}} }', '{}', NULL, NULL, NULL);
ERROR:  Invalid array index path e
SELECT documentdb_api_internal.update_bson_document('{"a": [1], "b": {"c": [2]}, "d": [{"e": 3}], "f": 4}', '{ "": { "$rename" :{"d.e":"d.c"}} }', '{}', NULL, NULL, NULL);
ERROR:  Invalid array index path e
SELECT documentdb_api_internal.update_bson_document('{"a": [1], "b": {"c": [2]}, "d": [{"e": 3}], "f": 4}', '{ "": { "$rename" :{"f":"a.0"}} }', '{}', NULL, NULL, NULL);
ERROR:  The target field of a rename cannot be an array element
-- $push top level input validation with all modifiers
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": {"$numberInt" : "2"}}', '{ "": { "$push" :{"a":"0"}} }', '{}', NULL, NULL, NULL);
ERROR:  The field 'a' is required to be an array, however it is currently of type int in document { _id: 1 }
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": {"$numberLong" : "2"}}', '{ "": { "$push" :{"a":"0"}} }', '{}', NULL, NULL, NULL);
ERROR:  The field 'a' is required to be an array, however it is currently of type long in document { _id: 1 }
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": {"$numberDouble" : "2.0"}}', '{ "": { "$push" :{"a":"0"}} }', '{}', NULL, NULL, NULL);
ERROR:  The field 'a' is required to be an array, however it is currently of type double in document { _id: 1 }
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": {"b" : [1,2,3]}}', '{ "": { "$push" :{"a":"0"}} }', '{}', NULL, NULL, NULL);
ERROR:  The field 'a' is required to be an array, however it is currently of type object in document { _id: 1 }
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": false}', '{ "": { "$push" :{"a":"0"}} }', '{}', NULL, NULL, NULL);
ERROR:  The field 'a' is required to be an array, however it is currently of type bool in document { _id: 1 }
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": NaN}', '{ "": { "$push" :{"a":"0"}} }', '{}', NULL, NULL, NULL);
ERROR:  The field 'a' is required to be an array, however it is currently of type double in document { _id: 1 }
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": "6" }}} }', '{}', NULL, NULL, NULL);
ERROR:  Expected 'array' type for $each in $push but found 'string' type
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": 6 }}} }', '{}', NULL, NULL, NULL);
ERROR:  Expected 'array' type for $each in $push but found 'int' type
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": {"a": 6} }}} }', '{}', NULL, NULL, NULL);
ERROR:  Expected 'array' type for $each in $push but found 'object' type
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$slice": 1.1 }}} }', '{}', NULL, NULL, NULL);
ERROR:  Expected 'array' type for $slice in $push but found 'double' type
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$slice": "2" }}} }', '{}', NULL, NULL, NULL);
ERROR:  Expected 'array' type for $slice in $push but found 'string' type
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$slice": true }}} }', '{}', NULL, NULL, NULL);
ERROR:  Expected 'array' type for $slice in $push but found 'bool' type
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$slice": [1,2,3] }}} }', '{}', NULL, NULL, NULL);
ERROR:  Expected 'array' type for $slice in $push but found 'array' type
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$sort": 0 }}} }', '{}', NULL, NULL, NULL);
ERROR:  The $sort element value must be either 1 or -1
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$sort": -2 }}} }', '{}', NULL, NULL, NULL);
ERROR:  The $sort element value must be either 1 or -1
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$sort": 2 }}} }', '{}', NULL, NULL, NULL);
ERROR:  The $sort element value must be either 1 or -1
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$sort": 1.1 }}} }', '{}', NULL, NULL, NULL);
ERROR:  The $sort element value must be either 1 or -1
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$sort": {"a.b": -2} }}} }', '{}', NULL, NULL, NULL);
ERROR:  The $sort element value must be either 1 or -1
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$sort": {"a.": -2} }}} }', '{}', NULL, NULL, NULL);
ERROR:  The $sort field is a dotted field but has an empty part: a.
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$sort": {".b.c": -2} }}} }', '{}', NULL, NULL, NULL);
ERROR:  The $sort field is a dotted field but has an empty part: .b.c
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$sort": {"": 1} }}} }', '{}', NULL, NULL, NULL);
ERROR:  The $sort field should not be left empty
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$sort": {} }}} }', '{}', NULL, NULL, NULL);
ERROR:  The $sort pattern is empty when it should be a set of fields.
-- TODO: Make the error compatible with mongo: "errmsg" : "Cannot create field 'y' in element {x: [ { y: 1 } ]}"
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "key": {"x": [{"y": [1]}, {"y": [2]}]}}', '{ "": { "$push" :{"key.x.y": 1 }}}', '{}', NULL, NULL, NULL);
ERROR:  Invalid array index path y
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "key": {"x": [{"y": [1]}, {"y": [2]}]}}', '{ "": { "$push" :{ "key.x": { "$each": [], "badplugin": 1} }}}', '{}', NULL, NULL, NULL);
ERROR:  Unrecognized clause in $push: badplugin
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$position": -0.1 }}} }', '{}', NULL, NULL, NULL);
ERROR:  The value for $position must be an integer value, not of type: double
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$position": 1.1 }}} }', '{}', NULL, NULL, NULL);
ERROR:  The value for $position must be an integer value, not of type: double
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$position": "start" }}} }', '{}', NULL, NULL, NULL);
ERROR:  The value for $position must be an integer value, not of type: string
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$position": false }}} }', '{}', NULL, NULL, NULL);
ERROR:  The value for $position must be an integer value, not of type: bool
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$position": {"a.b": -2} }}} }', '{}', NULL, NULL, NULL);
ERROR:  The value for $position must be an integer value, not of type: object
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" :{"a": { "$each": [], "$position": [1,2,3] }}} }', '{}', NULL, NULL, NULL);
ERROR:  The value for $position must be an integer value, not of type: array
