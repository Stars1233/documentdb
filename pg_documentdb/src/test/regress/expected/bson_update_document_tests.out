SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": 1 }', '{ "": { "$set": { "a": 2 } } }', '{}', NULL, NULL, NULL) as update_bson_document;
                       update_bson_document                       
------------------------------------------------------------------
 { "_id" : { "$numberInt" : "1" }, "a" : { "$numberInt" : "2" } }
(1 row)

