-- -- Note : This test intenionally provides { "$type" : "date" } instead of { "$$type" : "date" }
-- -- The API call returns Error due to a Bug in libbson library that fails to parse { "$type" : "date" }
-- -- If this test starts failing (i.e. api call does't return error), it may mean that the libbson bug has been fixed.
-- -- In that case $currentDate implementation in DocumentdbApi needs a fix as well (i.e. remove support for "$$type" since "$type" will work OK)
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": { "$date": { "$numberLong" : "1234567890000" }}}', '{ "": { "$currentDate": { "a": { "$type" : "date" } } } }', '{}', NULL, NULL, NULL);
ERROR:  invalid input syntax JSON for BSON: Code: '2', Message 'Missing "$binary" after "$type" reading type "binary"'
LINE 1: ... "$date": { "$numberLong" : "1234567890000" }}}', '{ "": { "...
                                                             ^
-- --Empty UpdateSpec check
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4] }', '{ "": { "$inc": { "": 11} } }', '{}', NULL, NULL, NULL);
ERROR:  The update path cannot be empty and is therefore invalid
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4] }', '{ "": { "$mul": { "a.": 11} } }', '{}', NULL, NULL, NULL);
ERROR:  Empty field name detected at path 'a.'
-- update scenario tests: $pop
-- -- $pop from begin of array
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$pop" :{"a": -1}} }', '{}', NULL, NULL, NULL) as update_bson_document;
                                                             update_bson_document                                                             
----------------------------------------------------------------------------------------------------------------------------------------------
 { "_id" : { "$numberInt" : "1" }, "a" : [ { "$numberInt" : "2" }, { "$numberInt" : "3" }, { "$numberInt" : "4" }, { "$numberInt" : "5" } ] }
(1 row)

SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1]}', '{ "": { "$pop" :{"a": -1}} }', '{}', NULL, NULL, NULL) as update_bson_document;
              update_bson_document              
------------------------------------------------
 { "_id" : { "$numberInt" : "1" }, "a" : [  ] }
(1 row)

