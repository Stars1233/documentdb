-- validate _id
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": { "$set": { "_id": {"$b": 2, "c":3} } } }', '{}', NULL, NULL, NULL) as update_bson_document;
ERROR:  _id fields may not contain '$'-prefixed fields: $b is not valid for storage.
-- replaceRoot/replaceWith with dotted paths.
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": [ { "$replaceWith": { "_id": 1, "a.b.c": 3 } } ] }', '{}', NULL, NULL, NULL) as update_bson_document;
ERROR:  FieldPath field names may not contain '.'. Consider using $getField or $setField
--upsert when querySpec has $all
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": {} }', '{"_id": 10, "x": { "$all" : {}}}', NULL, NULL, NULL) as update_bson_document;
ERROR:  $all needs an array
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": {} }', '{"_id": 11, "x": { "$all" : [1]}}', NULL, NULL, NULL) as update_bson_document;
        update_bson_document         
-------------------------------------
 { "_id" : { "$numberInt" : "11" } }
(1 row)

SELECT documentdb_api_internal.update_bson_document('{}', '{ "": {"$set":{"_id":12}}}', '{"x": { "$all" : [2]}}', NULL, NULL, NULL) as update_bson_document;
                       update_bson_document                        
-------------------------------------------------------------------
 { "_id" : { "$numberInt" : "12" }, "x" : { "$numberInt" : "2" } }
(1 row)

SELECT documentdb_api_internal.update_bson_document('{}', '{ "": {"$set":{"_id":13}}}', '{"x": { "$all" : [[3]]}}', NULL, NULL, NULL) as update_bson_document;
                         update_bson_document                          
-----------------------------------------------------------------------
 { "_id" : { "$numberInt" : "13" }, "x" : [ { "$numberInt" : "3" } ] }
(1 row)

SELECT documentdb_api_internal.update_bson_document('{}', '{ "": {"$set":{"_id":14}}}', '{"x": { "$all" : [{"x":11}]}}', NULL, NULL, NULL) as update_bson_document;
                             update_bson_document                             
------------------------------------------------------------------------------
