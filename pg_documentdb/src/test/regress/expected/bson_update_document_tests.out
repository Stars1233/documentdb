-- $push with $slice: 0 must empty a previously non-empty array (not a no-op)
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" : {"a": { "$each" : [], "$slice": 0 }} } }', '{}', NULL, NULL, NULL) as update_bson_document;
              update_bson_document              
------------------------------------------------
 { "_id" : { "$numberInt" : "1" }, "a" : [  ] }
(1 row)

SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": [1,2,3,4,5]}', '{ "": { "$push" : {"a": { "$each" : [6,7,8], "$sort": -1, "$slice": 0 }} } }', '{}', NULL, NULL, NULL) as update_bson_document;
              update_bson_document              
------------------------------------------------
 { "_id" : { "$numberInt" : "1" }, "a" : [  ] }
(1 row)

-- $push with $slice: 0 on an already-empty array is a no-op (result unchanged)
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": []}', '{ "": { "$push" : {"a": { "$each" : [], "$slice": 0 }} } }', '{}', NULL, NULL, NULL) as update_bson_document;
 update_bson_document 
----------------------
 
