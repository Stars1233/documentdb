-- $rename Negative/No-Op cases
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": { "$rename": { "a.": "b"} } }', '{}', NULL, NULL, NULL) as update_bson_document;
ERROR:  Empty field name detected at path 'a.'
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": { "$rename": { "$.": "b"} } }', '{}', NULL, NULL, NULL) as update_bson_document;
ERROR:  Empty field name detected at path '$.'
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": { "$rename": { "$[].0": "b"} } }', '{}', NULL, NULL, NULL) as update_bson_document;
ERROR:  Array filter identifier usage (e.g., '$[<id>]') is not permitted at the starting position of the specified path '$[].0'
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": { "$rename": { "a": "b."} } }', '{}', NULL, NULL, NULL) as update_bson_document;
ERROR:  Empty field name detected at path 'b.'
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": { "$rename": { "a": "$"} } }', '{}', NULL, NULL, NULL) as update_bson_document;
ERROR:  Positional element (i.e. '$') cannot appear at the beginning of the path '$'.
SELECT documentdb_api_internal.update_bson_document('{}', '{ "": { "$rename": { "a": "$[]"} } }', '{}', NULL, NULL, NULL) as update_bson_document;
ERROR:  Array filter identifier usage (e.g., '$[<id>]') is not permitted at the starting position of the specified path '$[]'
SELECT documentdb_api_internal.update_bson_document('{"a": 1, "f": 1}', '{ "": { "$rename": { "a": "f.g"} } }', '{}', NULL, NULL, NULL) as update_bson_document;
ERROR:  Failed to create the field 'f' within the element specified by {f : 1}
SELECT documentdb_api_internal.update_bson_document('{"a": 1, "f": 1}', '{ "": { "$rename": { "f.g": "a"} } }', '{}', NULL, NULL, NULL) as update_bson_document;
ERROR:  Failed to create the field 'f' within the element specified by {f : 1}
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "a": 1, "f": 1}', '{ "": { "$rename": { "x": "f.g"} } }', '{}', NULL, NULL, NULL) as update_bson_document;
