-- $push without $each but with other modifiers works on mongo5.0, $ is now supported in key names.
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "key": {"x": [{"y": [1]}, {"y": [2]}]}}', '{ "": { "$push" :{ "key.x": { "$eachh": [], "$position": 1, "$sort" : 1} }}}', '{}', NULL, NULL, NULL) as update_bson_document;
