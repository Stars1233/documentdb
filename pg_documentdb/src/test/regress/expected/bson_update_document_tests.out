-- update scenario negative tests: $bit
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "expdata" :"abc"}', '{ "": { "$bit": { "expdata" : { "or" :10 }  }  }}', '{}', NULL, NULL, NULL);
ERROR:  $bit cannot be used on a value that is not of an integral type. The document with _id = 1 contains the field expdata, which has a non-integer type string.
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "expdata" :13}', '{ "": { "$bit": { "expdata" : { "or" :10.0 }  }  }}', '{}', NULL, NULL, NULL);
ERROR:  The $bit modifier field must be an Integer(32/64 bit); a 'double' is not supported here: { "or" : 10 }
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "expdata" :13}', '{ "": { "$bit": { "expdata" : { "ors" :10 }  }  }}', '{}', NULL, NULL, NULL);
ERROR:  The $bit modifier only supports 'and', 'or', and 'xor', not 'ors' which is an unknown operator: { "ors" : 10 }
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "expdata" :[1,2,3]}', '{ "": { "$bit": { "expdata" : { "or" :10 }  }  }}', '{}', NULL, NULL, NULL);
ERROR:  $bit cannot be used on a value that is not of an integral type. The document with _id = 1 contains the field expdata, which has a non-integer type array.
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "expdata" :13}', '{ "": { "$bit": { "expdata" : {  }} }}', '{}', NULL, NULL, NULL);
ERROR:  You must pass in at least one bitwise operation. The format is: {$bit: {field: {and/or/xor: #}}
/* TODO: Make the error compatible with mongo: "errmsg" : "Cannot create field 'y' in element {x: [ { y: 10 } ]}"  */
SELECT documentdb_api_internal.update_bson_document('{"_id": 1, "key": {"x": [ { "y": 10 } ] }}', '{ "": { "$bit": { "key.x.y": { "and": 0 }}}}', '{}', NULL, NULL, NULL);
ERROR:  Invalid array index path y
