SET search_path TO documentdb_api,documentdb_api_catalog,documentdb_core,pg_catalog;
SET documentdb.next_collection_id TO 25705000;
SET documentdb.next_collection_index_id TO 25705000;
-- =============================================================================
-- $min / $max null / missing handling matrix.
--
-- The behavior is governed by two independent axes, so the tests below exercise
-- the full 2x2 grid for both $group and $setWindowFields:
--
--   Accumulator implementation:
--     * Legacy   -> enableNewMinMaxAccumulators = off, enableNewWithExprAccumulators = off
--     * WithExpr -> enableNewMinMaxAccumulators = on,  enableNewWithExprAccumulators = on
--
--   Skip-null flag (documentdb.enable_min_max_skip_null_values):
--     * on  -> $min / $max ignore explicit null and missing values, returning
--              null only when every value in the group is null / missing.
--     * off -> legacy behavior where an explicit null is a sortable value: it
--              wins $min (sorts below numbers) and, being above MinKey, changes
--              $max for a { MinKey, null } group.
--
-- Note the missing-only group ("miss"): on the legacy path a missing field is
-- projected to null, so with the flag off $min sees a null and returns null; on
-- the WithExpr path the missing field is already excluded, so $min is unchanged.
-- =============================================================================
SELECT documentdb_api.insert_one('db','minmax_null_test','{ "_id": "normal_100", "score": 100 }');
NOTICE:  creating collection
                              insert_one                              
----------------------------------------------------------------------
 { "n" : { "$numberInt" : "1" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

SELECT documentdb_api.insert_one('db','minmax_null_test','{ "_id": "normal_65", "score": 65 }');
                              insert_one                              
----------------------------------------------------------------------
 { "n" : { "$numberInt" : "1" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

SELECT documentdb_api.insert_one('db','minmax_null_test','{ "_id": "explicit_null", "score": null }');
                              insert_one                              
----------------------------------------------------------------------
 { "n" : { "$numberInt" : "1" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

SELECT documentdb_api.insert_one('db','minmax_null_test','{ "_id": "missing_score" }');
                              insert_one                              
----------------------------------------------------------------------
 { "n" : { "$numberInt" : "1" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

-- Group where every value is null or missing.
SELECT documentdb_api.insert_one('db','minmax_null_test','{ "_id": "all_null_1", "grp": "empty", "score": null }');
                              insert_one                              
----------------------------------------------------------------------
 { "n" : { "$numberInt" : "1" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

SELECT documentdb_api.insert_one('db','minmax_null_test','{ "_id": "all_null_2", "grp": "empty" }');
                              insert_one                              
----------------------------------------------------------------------
 { "n" : { "$numberInt" : "1" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

-- Group whose only non-null value is MinKey. MinKey sorts below null, so this is
-- the case where skipping null changes $max: skip-null on returns MinKey, while
-- skip-null off returns null (null sorts above MinKey).
SELECT documentdb_api.insert_one('db','minmax_null_test','{ "_id": "minkey_1", "grp": "mk", "score": { "$minKey": 1 } }');
                              insert_one                              
----------------------------------------------------------------------
 { "n" : { "$numberInt" : "1" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

