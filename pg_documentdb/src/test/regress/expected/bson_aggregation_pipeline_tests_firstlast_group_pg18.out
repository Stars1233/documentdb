-- 8. Top-level "let" passes varSpec to the with-expr transition function
SET documentdb.enableNewWithExprAccumulators TO on;
SELECT document FROM bson_aggregation_pipeline('db', '{ "aggregate": "fl_grp_test", "pipeline": [{ "$group": { "_id": "$g", "firstAdj": { "$first": { "$add": ["$v", "$$bonus"] } }, "lastAdj": { "$last": { "$add": ["$v", "$$bonus"] } } } }], "cursor": {}, "let": { "bonus": 100 } }');
                                           document                                           
----------------------------------------------------------------------------------------------
 { "_id" : "A", "firstAdj" : { "$numberInt" : "110" }, "lastAdj" : null }
 { "_id" : "B", "firstAdj" : null, "lastAdj" : { "$numberInt" : "140" } }
 { "_id" : "C", "firstAdj" : { "$numberInt" : "160" }, "lastAdj" : { "$numberInt" : "160" } }
(3 rows)

-- EXPLAIN shows non-empty varSpec with "let" variables
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('db', '{ "aggregate": "fl_grp_test", "pipeline": [{ "$group": { "_id": "$g", "f": { "$first": { "$add": ["$v", "$$bonus"] } } } }], "cursor": {}, "let": { "bonus": 100 } }');
                                                                                                                                                                                                                                                                                                                                                                                   QUERY PLAN                                                                                                                                                                                                                                                                                                                                                                                    
---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 GroupAggregate
   Output: bson_repath_and_build('_id'::text, (documentdb_api_internal.bson_expression_get(document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE, "let" : { "bonus" : { "$literal" : { "$numberInt" : "100" } } } }'::bson)), 'f'::text, documentdb_api_internal.bsonfirstwithexpr(document, '{ "" : { "$add" : [ "$v", "$$bonus" ] } }'::bson, '{ "now" : NOW_SYS_VARIABLE, "let" : { "bonus" : { "$literal" : { "$numberInt" : "100" } } } }'::bson, NULL::text)), (documentdb_api_internal.bson_expression_get(document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE, "let" : { "bonus" : { "$literal" : { "$numberInt" : "100" } } } }'::bson))
   Group Key: (documentdb_api_internal.bson_expression_get(collection.document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE, "let" : { "bonus" : { "$literal" : { "$numberInt" : "100" } } } }'::bson))
   ->  Sort
         Output: (documentdb_api_internal.bson_expression_get(document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE, "let" : { "bonus" : { "$literal" : { "$numberInt" : "100" } } } }'::bson)), document
         Sort Key: (documentdb_api_internal.bson_expression_get(collection.document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE, "let" : { "bonus" : { "$literal" : { "$numberInt" : "100" } } } }'::bson))
         ->  Bitmap Heap Scan on documentdb_data.documents_25701000 collection
               Output: documentdb_api_internal.bson_expression_get(document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE, "let" : { "bonus" : { "$literal" : { "$numberInt" : "100" } } } }'::bson), document
               Recheck Cond: (collection.shard_key_value = '25701000'::bigint)
               ->  Bitmap Index Scan on _id_
                     Index Cond: (collection.shard_key_value = '25701000'::bigint)
(11 rows)

