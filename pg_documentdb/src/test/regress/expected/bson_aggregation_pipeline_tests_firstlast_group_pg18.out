-- =============================================================================
-- 27. EXPLAIN matrix: sortBy on/off × GUC on/off for $first/$last in $setWindowFields
-- =============================================================================
-- 27a. GUC on, with sortBy → bsonfirst / bsonlast (sorted path, NOT WithExpr)
SET documentdb.enableNewWithExprAccumulators TO on;
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('db', '{ "aggregate": "fl_grp_test", "pipeline": [{ "$setWindowFields": { "partitionBy": "$g", "sortBy": { "v": 1 }, "output": { "f": { "$first": "$v" }, "l": { "$last": "$name" } } } }], "cursor": {} }');
                                                                                                                                                                                                                                                                                             QUERY PLAN                                                                                                                                                                                                                                                                                             
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Subquery Scan on agg_stage_0
   Output: documentdb_api_internal.bson_dollar_merge_documents(agg_stage_0.document, bson_repath_and_build('f'::text, agg_stage_0.f, 'l'::text, agg_stage_0.l), false)
   ->  WindowAgg
         Output: collection.document, (documentdb_api_internal.bsonfirst(collection.document, '{"{ \"v\" : { \"$numberInt\" : \"1\" } }"}'::bson[], '{ "" : "$v" }'::bson) OVER w1), documentdb_api_internal.bsonlast(collection.document, '{"{ \"v\" : { \"$numberInt\" : \"1\" } }"}'::bson[], '{ "" : "$name" }'::bson) OVER w2, (documentdb_api_internal.bson_expression_partition_get(collection.document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), (bson_orderby(collection.document, '{ "v" : { "$numberInt" : "1" } }'::bson))
         Window: w2 AS (PARTITION BY (documentdb_api_internal.bson_expression_partition_get(collection.document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)) ORDER BY (bson_orderby(collection.document, '{ "v" : { "$numberInt" : "1" } }'::bson)) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING)
         ->  WindowAgg
               Output: (documentdb_api_internal.bson_expression_partition_get(collection.document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), (bson_orderby(collection.document, '{ "v" : { "$numberInt" : "1" } }'::bson)), collection.document, documentdb_api_internal.bsonfirst(collection.document, '{"{ \"v\" : { \"$numberInt\" : \"1\" } }"}'::bson[], '{ "" : "$v" }'::bson) OVER w1
               Window: w1 AS (PARTITION BY (documentdb_api_internal.bson_expression_partition_get(collection.document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)) ORDER BY (bson_orderby(collection.document, '{ "v" : { "$numberInt" : "1" } }'::bson)) ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING)
               ->  Sort
                     Output: (documentdb_api_internal.bson_expression_partition_get(collection.document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), (bson_orderby(collection.document, '{ "v" : { "$numberInt" : "1" } }'::bson)), collection.document
                     Sort Key: (documentdb_api_internal.bson_expression_partition_get(collection.document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), (bson_orderby(collection.document, '{ "v" : { "$numberInt" : "1" } }'::bson)) NULLS FIRST
                     ->  Bitmap Heap Scan on documentdb_data.documents_25701000 collection
                           Output: documentdb_api_internal.bson_expression_partition_get(collection.document, '{ "" : "$g" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson), bson_orderby(collection.document, '{ "v" : { "$numberInt" : "1" } }'::bson), collection.document
                           Recheck Cond: (collection.shard_key_value = '25701000'::bigint)
                           ->  Bitmap Index Scan on _id_
                                 Index Cond: (collection.shard_key_value = '25701000'::bigint)
