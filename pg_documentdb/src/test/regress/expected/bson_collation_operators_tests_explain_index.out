-- ======================================================================
-- SECTION 2: $eq — equality pushdown
-- ======================================================================
-- 2.1: $eq with matching collation — index SHOULD be used
SELECT documentdb_test_helpers.run_explain_and_trim($cmd$
    EXPLAIN (COSTS OFF, ANALYZE ON, SUMMARY OFF, TIMING OFF, BUFFERS OFF) SELECT document FROM bson_aggregation_find('coll_operators_index_explain_db', '{ "find": "single_field", "filter": { "a": { "$eq": "apple" } }, "sort": { "_id": 1 }, "collation": { "locale": "en", "strength": 1 } }')
$cmd$);
                                                                  run_explain_and_trim                                                                  
--------------------------------------------------------------------------------------------------------------------------------------------------------
 Sort (actual rows=2 loops=1)
   Sort Key: (documentdb_api_internal.bson_orderby(document, '{ "_id" : { "$numberInt" : "1" } }'::bson, 'en-u-ks-level1'::text)) USING <<< NULLS FIRST
   Sort Method: quicksort  Memory: xxxkB
   ->  Custom Scan (DocumentDBApiExplainQueryScan) (actual rows=2 loops=1)
         namespaceName: coll_operators_index_explain_db.single_field
         indexName: idx_a_en_s1
         indexKey: {"a": 1}
         isMultiKey: false
         indexBounds: ["a": ["apple", "apple"]]
         ->  Index Scan using idx_a_en_s1 on documents_9501 collection (actual rows=2 loops=1)
               Index Cond: (document @= '{ "a" : "apple", "collation" : "en-u-ks-level1" }'::bson)
(11 rows)

