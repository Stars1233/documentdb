   ->  Seq Scan on documentdb_data.documents_2601 collection
         Output: documentdb_api_internal.bson_expression_get(document, '{ "" : "$a" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson), document
(5 rows)

