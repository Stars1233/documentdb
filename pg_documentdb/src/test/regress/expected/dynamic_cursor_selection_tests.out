         Filter: (collection.document @= '{ "a" : { "$numberInt" : "1" } }'::bson)
(7 rows)

SET documentdb.enableDynamicCursors TO off;
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_find('dyncurdb', '{ "find": "dyncoll", "filter": { "a": 1 }, "projection": { "b": 1 } }');
                                                                                                                                       QUERY PLAN                                                                                                                                        
-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Custom Scan (DocumentDBApiScan)
   Output: documentdb_api_internal.bson_dollar_project_find(document, '{ "b" : { "$numberInt" : "1" } }'::bson, '{ "a" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson), documentdb_api_internal.current_cursor_state(document)
   ->  Tid Range Scan on documentdb_data.documents_2601 collection
         Output: shard_key_value, object_id, document
         TID Cond: (collection.ctid >= '(0,0)'::tid)
         Filter: ((collection.document @= '{ "a" : { "$numberInt" : "1" } }'::bson) AND documentdb_api_internal.cursor_state(collection.document, '{ }'::bson))
(6 rows)

-- Scenario 6: Find with skip only (non-streamable)
-- TODO: skip should be streamable with dynamic cursors when the skip offset
-- can be tracked in the continuation state.
SET documentdb.enableDynamicCursors TO on;
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_find('dyncurdb', '{ "find": "dyncoll", "skip": 2 }');
                         QUERY PLAN                          
-------------------------------------------------------------
 Limit
   Output: document
   ->  Seq Scan on documentdb_data.documents_2601 collection
         Output: document
(4 rows)

SET documentdb.enableDynamicCursors TO off;
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_find('dyncurdb', '{ "find": "dyncoll", "skip": 2 }');
                         QUERY PLAN                          
-------------------------------------------------------------
 Limit
   Output: document
   ->  Seq Scan on documentdb_data.documents_2601 collection
         Output: document
(4 rows)

-- Scenario 7: Find with sort only (non-streamable)
-- TODO: sort on an indexed field should be streamable with dynamic cursors
-- when the sort order matches the index order (index-pushed sort).
SET documentdb.enableDynamicCursors TO on;
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_find('dyncurdb', '{ "find": "dyncoll", "sort": { "a": 1 } }');
                                              QUERY PLAN                                               
-------------------------------------------------------------------------------------------------------
 Sort
   Output: document, (bson_orderby(document, '{ "a" : { "$numberInt" : "1" } }'::bson))
   Sort Key: (bson_orderby(collection.document, '{ "a" : { "$numberInt" : "1" } }'::bson)) NULLS FIRST
   ->  Seq Scan on documentdb_data.documents_2601 collection
         Output: document, bson_orderby(document, '{ "a" : { "$numberInt" : "1" } }'::bson)
(5 rows)

SET documentdb.enableDynamicCursors TO off;
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_find('dyncurdb', '{ "find": "dyncoll", "sort": { "a": 1 } }');
                                              QUERY PLAN                                               
-------------------------------------------------------------------------------------------------------
 Sort
   Output: document, (bson_orderby(document, '{ "a" : { "$numberInt" : "1" } }'::bson))
   Sort Key: (bson_orderby(collection.document, '{ "a" : { "$numberInt" : "1" } }'::bson)) NULLS FIRST
   ->  Seq Scan on documentdb_data.documents_2601 collection
         Output: document, bson_orderby(document, '{ "a" : { "$numberInt" : "1" } }'::bson)
(5 rows)

