                              insert_one                              
----------------------------------------------------------------------
 { "n" : { "$numberInt" : "1" }, "ok" : { "$numberDouble" : "1.0" } }
(1 row)

-- Stage: $match (streamable - RequiresPersistentCursorFalse)
SET documentdb.enableDynamicCursors TO on;
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('dyncurdb', '{ "aggregate": "dyncoll", "pipeline": [{ "$match": { "a": 1 } }], "cursor": {} }');
                                     QUERY PLAN                                     
------------------------------------------------------------------------------------
 Custom Scan (DocumentDBApiCursorScan) on documentdb_data.documents_2601 collection
   Output: document
   ->  Index Scan using _id_ on documentdb_data.documents_2601 collection
         Output: document
         Filter: (collection.document @= '{ "a" : { "$numberInt" : "1" } }'::bson)
(5 rows)

SET documentdb.enableDynamicCursors TO off;
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('dyncurdb', '{ "aggregate": "dyncoll", "pipeline": [{ "$match": { "a": 1 } }], "cursor": {} }');
                                                                           QUERY PLAN                                                                           
----------------------------------------------------------------------------------------------------------------------------------------------------------------
 Custom Scan (DocumentDBApiScan)
   Output: document, documentdb_api_internal.current_cursor_state(document)
   ->  Tid Range Scan on documentdb_data.documents_2601 collection
         Output: shard_key_value, object_id, document
         TID Cond: (collection.ctid >= '(0,0)'::tid)
         Filter: ((collection.document @= '{ "a" : { "$numberInt" : "1" } }'::bson) AND documentdb_api_internal.cursor_state(collection.document, '{ }'::bson))
(6 rows)

-- Stage: $addFields (streamable - RequiresPersistentCursorFalse)
SET documentdb.enableDynamicCursors TO on;
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('dyncurdb', '{ "aggregate": "dyncoll", "pipeline": [{ "$addFields": { "c": 1 } }], "cursor": {} }');
                                                                                        QUERY PLAN                                                                                         
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Custom Scan (DocumentDBApiCursorScan)
   Output: (documentdb_api_internal.bson_dollar_add_fields(document, '{ "c" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson))
   ->  Index Scan using _id_ on documentdb_data.documents_2601 collection
         Output: documentdb_api_internal.bson_dollar_add_fields(document, '{ "c" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson)
         Filter: (collection.shard_key_value = '2601'::bigint)
(5 rows)

SET documentdb.enableDynamicCursors TO off;
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('dyncurdb', '{ "aggregate": "dyncoll", "pipeline": [{ "$addFields": { "c": 1 } }], "cursor": {} }');
                                                                                                                 QUERY PLAN                                                                                                                  
