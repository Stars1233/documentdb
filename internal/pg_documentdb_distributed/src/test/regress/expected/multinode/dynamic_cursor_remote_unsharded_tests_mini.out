NOTICE:  Page 4: batch=10, coordinator_holds_portal=f, kind=DynamicStreamingRemote, scan_type=QueryScanType_SecondaryIndexScan, remote_shard=documents_42001_4200002, idx=documents_rum_index_42002_4200002, portal=<NULL>
