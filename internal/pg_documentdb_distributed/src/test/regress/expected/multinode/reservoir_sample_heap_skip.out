ROLLBACK;
-- Flag off: same GUCs, so the base path is still a Bitmap Heap Scan on value_1.
-- With no rewrite the plan keeps it and stays "Materialize", proving the setup
-- really produces a bitmap for the flag on block to convert.
BEGIN;
SET LOCAL enable_indexscan TO off;
SET LOCAL enable_seqscan TO off;
SET LOCAL documentdb.enableDollarSampleHeapSkipReservoirScan TO off;
SELECT documentdb_distributed_test_helpers.run_explain_and_trim($$ EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_pipeline('rsampledb', '{ "aggregate": "heapskip_bmp", "pipeline": [ { "$match": { "value": { "$gte": 190 } } }, { "$sample": { "size": 5 } } ] }') $$);
                                                                                                                                                                                             run_explain_and_trim                                                                                                                                                                                             
---------------------------------------------------------------------
 Custom Scan (Citus Adaptive)
   Output: remote_scan.document
   Task Count: 1
   Tasks Shown: All
   ->  Task
         Query: SELECT document FROM documentdb_data.documents_7202_72004 collection WHERE ((document OPERATOR(documentdb_api_catalog.#>=) '{ "value" : { "$numberInt" : "190" } }'::documentdb_core.bsonquery) AND (shard_key_value OPERATOR(pg_catalog.=) '7202'::bigint) AND documentdb_api_internal.bson_dollar_range(document, '{ "" : { "sample" : { "$numberLong" : "5" } } }'::documentdb_core.bson))
         Node: host=localhost port=58081 dbname=postgres
         ->  Custom Scan (DocumentDBApiReservoirSample)
