        2 | { "cursor" : { "nextBatch" : [ { "_id" : { "$numberInt" : "10" }, "a" : { "$numberInt" : "1" }, "b" : { "$numberInt" : "4" } }, { "_id" : { "$numberInt" : "3" }, "a" : { "$numberInt" : "2" }, "b" : { "$numberInt" : "1" } }, { "_id" : { "$numberInt" : "6" }, "a" : { "$numberInt" : "2" }, "b" : { "$numberInt" : "2" } } ] } }
        3 | { "cursor" : { "nextBatch" : [ { "_id" : { "$numberInt" : "9" }, "a" : { "$numberInt" : "2" }, "b" : { "$numberInt" : "5" } }, { "_id" : { "$numberInt" : "1" }, "a" : { "$numberInt" : "3" }, "b" : { "$numberInt" : "2" } }, { "_id" : { "$numberInt" : "5" }, "a" : { "$numberInt" : "3" }, "b" : { "$numberInt" : "4" } } ] } }
        4 | { "cursor" : { "nextBatch" : [ { "_id" : { "$numberInt" : "8" }, "a" : { "$numberInt" : "3" }, "b" : { "$numberInt" : "3" } } ] } }
