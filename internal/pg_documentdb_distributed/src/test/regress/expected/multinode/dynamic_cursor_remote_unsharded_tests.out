   Task Count: 1
   Tasks Shown: All
   ->  Task
         Query: SELECT documentdb_api_internal.bson_dollar_project_find(document, '{ "_id" : { "$numberInt" : "1" }, "val" : { "$numberInt" : "1" } }'::documentdb_core.bson, '{ }'::documentdb_core.bson, '{ "now" : NOW_SYS_VARIABLE }'::documentdb_core.bson) AS document FROM documentdb_data.documents_41000_4100000 collection WHERE ((shard_key_value OPERATOR(pg_catalog.=) '41000'::bigint) AND documentdb_api_internal.cursor_tracker(document, '{ }'::documentdb_core.bson) AND documentdb_api_internal.bson_dollar_fullscan(document, '{ "val" : { "$numberInt" : "1" } }'::documentdb_core.bson)) ORDER BY (documentdb_api_catalog.bson_orderby(document, '{ "val" : { "$numberInt" : "1" } }'::documentdb_core.bson)) NULLS FIRST
         Node: host=localhost port=58081 dbname=postgres
         ->  Sort
               Output: (documentdb_api_internal.bson_dollar_project_find(document, '{ "_id" : { "$numberInt" : "1" }, "val" : { "$numberInt" : "1" } }'::documentdb_core.bson, '{ }'::documentdb_core.bson, '{ "now" : NOW_SYS_VARIABLE }'::documentdb_core.bson)), (documentdb_api_catalog.bson_orderby(document, '{ "val" : { "$numberInt" : "1" } }'::documentdb_core.bson))
               Sort Key: (documentdb_api_catalog.bson_orderby(collection.document, '{ "val" : { "$numberInt" : "1" } }'::documentdb_core.bson)) NULLS FIRST
               ->  Seq Scan on documentdb_data.documents_41000_4100000 collection
