NOTICE:  Page 3: batch=5, coordinator_holds_portal=f, kind=DynamicStreamingRemote, scan_type=QueryScanType_SecondaryIndexScan, remote_shard=documents_41000_4100000, idx=documents_rum_index_41003_4100000, portal=<NULL>
