                           Node: host=localhost port=58070 dbname=regression
                           ->  HashAggregate
                                 Output: '_id'::text, (documentdb_api_internal.bson_expression_get(agg_stage_3.document, '{ "" : "$ownerId" }'::documentdb_core.bson, true, '{ "now" : NOW_SYS_VARIABLE }'::documentdb_core.bson))
                                 Group Key: documentdb_api_internal.bson_expression_get(agg_stage_3.document, '{ "" : "$ownerId" }'::documentdb_core.bson, true, '{ "now" : NOW_SYS_VARIABLE }'::documentdb_core.bson)
