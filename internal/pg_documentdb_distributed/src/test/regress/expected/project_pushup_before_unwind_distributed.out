                                       Filter: (agg_stage_3.document OPERATOR(documentdb_api_catalog.#=) '{ "items.kind" : "x" }'::documentdb_core.bsonquery)
                                       ->  ProjectSet
                                             Output: documentdb_api_catalog.bson_dollar_unwind(documentdb_api_internal.bson_dollar_project(collection.document, '{ "ownerId" : { "$numberInt" : "1" }, "items" : { "$numberInt" : "1" }, "_id" : { "$numberInt" : "0" } }'::documentdb_core.bson, '{ "now" : NOW_SYS_VARIABLE }'::documentdb_core.bson), '$items'::text)
