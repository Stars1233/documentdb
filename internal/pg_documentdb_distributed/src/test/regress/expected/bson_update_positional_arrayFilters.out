    '{ "": { "$set": { "data.$[d].matched": true }}}', '{}',
    '{ "": [{ "$or": [{ "$and": [{ "d.x": { "$gte": 1 } }, { "d.x": { "$lte": 2 } }] }, { "$and": [{ "d.y": { "$gte": 35 } }, { "d.y": { "$lte": 45 } }] }] }] }',
    NULL::documentdb_core.bson, NULL::TEXT);
                                                                                                                                                                           update_bson_document                                                                                                                                                                            
---------------------------------------------------------------------
 { "_id" : { "$numberInt" : "1" }, "data" : [ { "x" : { "$numberInt" : "1" }, "y" : { "$numberInt" : "10" }, "matched" : true }, { "x" : { "$numberInt" : "2" }, "y" : { "$numberInt" : "20" }, "matched" : true }, { "x" : { "$numberInt" : "3" }, "y" : { "$numberInt" : "30" } }, { "x" : { "$numberInt" : "4" }, "y" : { "$numberInt" : "40" }, "matched" : true } ] }
(1 row)

