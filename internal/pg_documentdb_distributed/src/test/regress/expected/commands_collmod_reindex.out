Indexes:
    "collection_pk_1984304" PRIMARY KEY, btree (shard_key_value, object_id)
    "documents_rum_index_1984314" EXCLUDE USING documentdb_rum (document bson_rum_composite_path_ops (pathspec='[ "a" ]', tl='2691') WITH =?=, generate_unique_shard_document(document, shard_key_value, '{ "a" : { "$numberInt" : "1" } }'::bson, false, true) bson_rum_unique_shard_path_ops (cmp='true') WITH =#=)
Check constraints:
    "shard_key_value_check" CHECK (shard_key_value = '1984304'::bigint)

