BEGIN;
SET LOCAL documentdb_core.enableCollation TO on;
SET LOCAL documentdb.enableCollationWithNonUniqueOrderedIndexes TO on;
SET LOCAL enable_seqscan TO OFF;
SET LOCAL documentdb.enableExtendedExplainPlans TO on;
EXPLAIN (COSTS OFF) SELECT document FROM bson_aggregation_find('coll_idx_d_db', '{ "find": "single_field_d", "filter": { "a": { "$eq": "apple" } }, "sort": { "_id": 1 }, "collation": { "locale": "en", "strength": 1 } }');
                                                                           QUERY PLAN                                                                           
---------------------------------------------------------------------
 Sort
   Sort Key: remote_scan."?sort?" USING <<< NULLS FIRST
   ->  Custom Scan (Citus Adaptive)
         Task Count: 8
         Tasks Shown: One of 8
         ->  Task
               Node: host=localhost port=58070 dbname=regression
               ->  Custom Scan (DocumentDBApiExplainQueryScan)
                     indexName: idx_a_en_s1
                     indexKey: {"a": 1}
                     isMultiKey: false
                     indexBounds: ["a": ["apple", "apple"]]
                     ->  Index Scan using idx_a_en_s1 on documents_89001_89000004 collection
                           Index Cond: (document OPERATOR(documentdb_api_catalog.@=) '{ "a" : "apple", "collation" : "en-u-ks-level1" }'::documentdb_core.bson)
(14 rows)

END;
