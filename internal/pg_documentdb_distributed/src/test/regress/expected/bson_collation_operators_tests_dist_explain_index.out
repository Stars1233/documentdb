         Task Count: 8
         Tasks Shown: One of 8
         ->  Task
               Node: host=localhost port=58070 dbname=regression
               ->  Custom Scan (DocumentDBApiExplainQueryScan)
                     indexName: idx_a_en_s1
                     indexKey: {"a": 1}
                     isMultiKey: false
                     indexBounds: ["a": ["apple", "apple"]]
                     ->  Index Scan using idx_a_en_s1 on documents_95211_95210004 collection
                           Index Cond: (document OPERATOR(documentdb_api_catalog.@=) '{ "a" : "apple", "collation" : "en-u-ks-level1" }'::documentdb_core.bson)
(14 rows)

END;
