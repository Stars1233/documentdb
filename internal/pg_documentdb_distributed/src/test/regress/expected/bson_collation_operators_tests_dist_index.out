 { "_id" : { "$numberInt" : "2" }, "items" : [ "apple", "BANANA", "cherry" ] }
 { "_id" : { "$numberInt" : "4" }, "items" : [ "Dog", "elephant", "FOX" ] }
(3 rows)

END;
