         Output: agg_stage_2.document, bson_orderby(agg_stage_2.document, '{ "_id" : { "$numberInt" : "1" } }'::bson)
         ->  GroupAggregate
               Output: bson_repath_and_build('_id'::text, (bson_expression_get(collection.document, '{ "" : "$_id" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), 'c'::text, bsonsumwithexpr('{ }'::bson, '{ "" : { "$numberInt" : "1" } }'::bson, '{ "now" : NOW_SYS_VARIABLE }'::bson, NULL::text)), (bson_expression_get(collection.document, '{ "" : "$_id" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))
               Group Key: bson_expression_get(collection.document, '{ "" : "$_id" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)
               ->  Index Scan using _id_ on documentdb_data.documents_18401_1840002 collection
                     Output: bson_expression_get(collection.document, '{ "" : "$_id" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson), collection.document
                     Index Cond: ((collection.shard_key_value = '18401'::bigint) AND (collection.object_id > '{ "" : { "$numberInt" : "0" } }'::bson) AND (collection.object_id <= '{ "" : { "$numberDouble" : "Infinity" } }'::bson))
(11 rows)

-- (5) $sort on just _id. With the GUC enabled the order-by pushdown re-adds the shard_key_value
-- qual (only to anchor the _id_ index) and, with bitmap scans disabled, a filter-less $sort is
-- served directly by an ordered Index Scan using _id_ (Index Scan Backward for descending) with
-- the sort pushed down to the index - no separate Sort node. Supplying an _id filter keeps the
-- same ordered Index Scan using _id_ for both filtering and ordering.
EXPLAIN (COSTS OFF, VERBOSE ON) SELECT document FROM bson_aggregation_find('pkdb', '{ "find": "pk_native", "sort": { "_id": 1 } }');
                                       QUERY PLAN                                       
---------------------------------------------------------------------
 Index Scan using _id_ on documentdb_data.documents_18401_1840002 collection
   Output: document, bson_orderby(document, '{ "_id" : { "$numberInt" : "1" } }'::bson)
   Index Cond: (collection.shard_key_value = '18401'::bigint)
(3 rows)

