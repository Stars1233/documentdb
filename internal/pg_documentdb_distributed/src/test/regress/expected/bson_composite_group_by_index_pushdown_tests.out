                                                                                                                                                                                                                                                                                                                                                                                                QUERY PLAN                                                                                                                                                                                                                                                                                                                                                                                                
---------------------------------------------------------------------
 HashAggregate
   Output: bson_repath_and_build('_id'::text, bson_repath_and_build('b'::text, (bson_expression_get(document, '{ "" : "$b" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), 'd'::text, (bson_expression_get(document, '{ "" : "$d" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))), 'total'::text, bsonsum(bson_expression_get(document, '{ "" : "$a" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))), (bson_expression_get(document, '{ "" : "$b" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)), (bson_expression_get(document, '{ "" : "$d" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson))
   Group Key: bson_expression_get(collection.document, '{ "" : "$b" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson), bson_expression_get(collection.document, '{ "" : "$d" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)
   ->  Index Scan using b_c_1 on documentdb_data.documents_8601_860002 collection
         Output: bson_expression_get(document, '{ "" : "$b" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson), bson_expression_get(document, '{ "" : "$d" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson), document
         Index Cond: (collection.document @<> '{ "b" : { "orderByScan" : { "$numberInt" : "1" } } }'::bson)
