 HashAggregate
   Group Key: bson_expression_get(document, '{ "" : { "b" : "$b", "offset" : "$$myVar" } }'::bson, true, '{ "now" : NOW_SYS_VARIABLE, "let" : { "myVar" : { "$literal" : { "$numberInt" : "42" } } } }'::bson)
   ->  Index Scan using _id_ on documents_8601_860002 collection
         Index Cond: (shard_key_value = '8601'::bigint)
(4 rows)

BEGIN;
set citus.enable_local_execution to off;
