   Group Key: bson_expression_get(document, '{ "" : "$c" }'::bson, true, '{ "now" : NOW_SYS_VARIABLE }'::bson)
   ->  Index Scan using b_c_1 on documents_8601_860002 collection
         Index Cond: (document @= '{ "b" : { "$numberInt" : "10" } }'::bson)
         Order By: (document |-<> '{ "c" : { "$numberInt" : "1" } }'::bson)
(5 rows)

